ORGANIZATION_BLOCK "Main"
TITLE = "Main Program Sweep (Cycle)"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
// =====================================================================
// SCARA ABCDE — Main (OB1)
//
// 2026-05-17 — Minimal main cyclic OB for ABCDE 5-point demo.
//
// Block call count (vs v9 ~50+ MC instructions per scan → OB91 overflow):
//   1× LKinCtrl_MC_GroupPower (wraps Array[1..6] MC_POWER)
//   1× LKinCtrl_MC_GroupHome  (wraps Array[1..6] MC_HOME)
//   1× LKinCtrl_MC_GroupReset (wraps Array[1..6] MC_RESET + 1 kin reset)
//   1× FB_AutoCtrl_ABCDE (instance contains 1 MC_MoveLinearAbsolute)
//
// Concurrent system MC instructions per scan: ~6+6+6+1 = ~19, but only
// 1 (MC_MoveLinearAbsolute) is actively pulsing motion — the other 18
// sit idle (Execute=FALSE) so OB91 sees ~3-4 active TO command slots,
// well under the buffer limit. (v9's failure was ~50 actively pulsing.)
//
// Axis_Call has been merged inline here — eliminates a separate sub-FC
// (one less indirection, easier to read in this minimal demo).
// =====================================================================

BEGIN
	REGION Group_Power
	    // Enable all 4 joint axes via the kinematic group.
	    // axesEnabled mirror feeds FB_AutoCtrl_ABCDE permissive gate.
	    "instLKinCtrl_MC_GroupPower"(enable    := "GDB_Control".enableAxes,
	                                 startMode := "GDB_Control".StartMode,
	                                 stopMode  := "GDB_Control".StopMode,
	                                 axesGroup := "ScaraArm3D");
	    "GDB_Control".axesEnabled := "instLKinCtrl_MC_GroupPower".axesEnabled;
	END_REGION

	REGION Group_Reset
	    // Reset axis errors via the kinematic group.
	    // Single rising-edge from HMI resetAxes button.
	    "instLKinCtrl_MC_GroupReset"(execute   := "GDB_Control".resetAxes,
	                                 restart   := "GDB_Control".RestartMode,
	                                 axesGroup := "ScaraArm3D");
	    "GDB_Control".axesError := "instLKinCtrl_MC_GroupReset".error;
	END_REGION

	REGION Group_Home
	    // Home all 4 joints via "set actual position" (HomeMode[i]=7).
	    // After Done, mirror to axesHomed so FB_AutoCtrl_ABCDE permissive
	    // can pass and allow Start.
	    "instLKinCtrl_MC_GroupHome"(execute   := "GDB_Control".homeAxes,
	                               position  := "GDB_Control".HomePos,
	                               mode      := "GDB_Control".HomeMode,
	                               axesGroup := "ScaraArm3D");
	    IF "instLKinCtrl_MC_GroupHome".done THEN
	        "GDB_Control".axesHomed := TRUE;
	    END_IF;
	END_REGION

	REGION Auto_Cycle
	    // The centerpiece: Wang Shuo 4-REGION pattern with single
	    // MC_MoveLinearAbsolute that re-pulses Execute per ABCDE step.
	    "instFB_AutoCtrl_ABCDE"();
	END_REGION

END_ORGANIZATION_BLOCK
