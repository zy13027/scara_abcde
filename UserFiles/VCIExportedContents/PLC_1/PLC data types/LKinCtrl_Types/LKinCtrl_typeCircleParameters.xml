  <SW.Types.PlcStruct ID="0">
    <AttributeList>
      <Interface><Sections xmlns="http://www.siemens.com/automation/Openness/SW/Interface/v5">
  <Section Name="None">
    <Member Name="circMode" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">0: auxPoint defines point on circle line; 1: auxPoint defines circle center; 2: radius and endPoint define circle segment; 3: GCode notation (end &amp; aux point)</MultiLanguageText>
      </Comment>
      <StartValue>0</StartValue>
    </Member>
    <Member Name="point" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">reference to point table, used for auxPoint</MultiLanguageText>
      </Comment>
      <StartValue>-1</StartValue>
    </Member>
    <Member Name="auxPoint" Datatype="Array[1..3] of LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">auxiliary point for circle definition</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="pathChoice" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">circMode(0): not relevant; circMode(1): 0: pos direction; 1: neg direction; circMode(2): 0: short pos segment; 1: short neg segment; 2: long pos segment; 3: long neg segment</MultiLanguageText>
      </Comment>
      <StartValue>0</StartValue>
    </Member>
    <Member Name="circlePlane" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">circMode(0): not relevant; circMode(1+2): 0: XZ; 1: YZ; 2: XY</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="radius" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">only in combination with circMode(2): radius</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="arc" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">only in combination with  circMode(1): arc</MultiLanguageText>
      </Comment>
    </Member>
  </Section>
