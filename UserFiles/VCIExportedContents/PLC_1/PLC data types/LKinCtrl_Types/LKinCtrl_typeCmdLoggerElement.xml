      </Comment>
    </Member>
    <Member Name="positionMode" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">1: absolute cartesian position and absolute orientation; 2: absolute cartesian position and relative orientation (effective for MoveDirect commands only)</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="circMode" Datatype="DInt">
