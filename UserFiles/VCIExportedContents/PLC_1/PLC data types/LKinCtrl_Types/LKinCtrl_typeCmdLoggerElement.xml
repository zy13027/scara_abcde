    <Member Name="pathDataIdentifier" Datatype="Int">
      <Comment>
        <MultiLanguageText Lang="en-US">identifier of PathData containing command</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="cmdID" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">to be set to PathDataOperate[list position] by PreBuffer for identification in ExecuteBuffer</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="cmdName" Datatype="String[4]">
      <Comment>
        <MultiLanguageText Lang="en-US">command name</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="coordinateX" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">X (linear) / endPoint[1] (circular)</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="coordinateY" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">Y (linear) / endPoint[2] (circular)</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="coordinateZ" Datatype="LReal">
      <Comment>
