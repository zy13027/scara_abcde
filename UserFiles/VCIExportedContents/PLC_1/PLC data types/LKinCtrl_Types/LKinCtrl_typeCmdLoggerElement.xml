      </Comment>
    </Member>
    <Member Name="dynAcceleration" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">&gt;0.0: configured value used; &lt;0.0: default TO setting used</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="dynDeceleration" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">&gt;0.0: configured value used; &lt;0.0: default TO setting used</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="dynJerk" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">&gt;0.0: configured value used; &lt;0.0: default TO setting used</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="dynamicAdpation" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">&lt;0.0: default TO setting used; 0: no dynamic adaption; 1: with variable limits; 2: with constant limits</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="linkConstellation" Datatype="DWord">
