      </Comment>
    </Member>
    <Member Name="pathChoice" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">circMode(0): not relevant; circMode(1): 0: pos direction; 1: neg direction; circMode(2): 0: short pos segment; 1: short neg segment; 2: long pos segment; 3: long neg segment</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="circlePlane" Datatype="DInt">
      <Comment>
        <MultiLanguageText Lang="en-US">circMode(0): not relevant; circMode(1+2): 0: XZ; 1: YZ; 2: XY</MultiLanguageText>
