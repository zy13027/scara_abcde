      </Comment>
    </Member>
    <Member Name="x" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">MOVE: target Cartesian X [mm]</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="y" Datatype="LReal">
      <Comment>
        <MultiLanguageText Lang="en-US">MOVE: target Cartesian Y [mm]</MultiLanguageText>
      </Comment>
    </Member>
    <Member Name="z" Datatype="LReal">
      <Comment>
