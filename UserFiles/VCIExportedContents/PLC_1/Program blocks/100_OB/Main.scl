ORGANIZATION_BLOCK "Main"
TITLE = "Main Program Sweep (Cycle)"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
// =====================================================================
// SCARA ABCDE â€” Main (OB1)
// (2026-05-17 rev 2 â€” rewritten per approved plan zazzy-mixing-hammock.md)
//
// CHANGES vs v1.0 (backed up at .backup/2026-05-17/100_OB/Main.scl):
//   - Removed inline LKinCtrl_MC_GroupPower / GroupHome / GroupReset calls
//     per source spec line 11 ("ä¸ç”¨ä»»ä½•çš„åº“" / no libraries)
//   - Delegates per-axis MC_Power/Home + system MC_GroupReset to new
//     FB_AxisCtrl (multi-instance MC iDBs co-located in one FB iDB)
//
// PER-SCAN MC INSTRUCTION COUNT:
//   FB_AxisCtrl:           4Ã— MC_Power + 4Ã— MC_Home + 1Ã— MC_GroupReset = 9
//   FB_AutoCtrl_ABCDE:     1Ã— MC_MoveLinearAbsolute                    = 1
//   Total declared:                                                   10
//   Actively pulsing at any time:                                ~4-5 (vs v9's ~50 â†’ OB91 overflow)
//   Result: V-OB91 buffer overflow gate should pass after 30s continuous cycle
//
// Block call sequence (cyclic, every scan):
//   1. instFB_AxisCtrl()           â€” enable / home / reset kinematic group
//   2. instFB_AutoCtrl_ABCDE()     â€” Wang Shuo 4-REGION ABCDE state machine
//   3. instFB_MCDDataTransfer()    â€” publish TO data to GDB_MCDData for MCD viewport
// =====================================================================

BEGIN
	
	 REGION Axis_Control
	     // Per-axis MC_Power / MC_Home + system MC_GroupReset.
	     // Replaces what was 3Ã— LKinCtrl_MC_Group* wrappers in v1.0.
	     "instFB_AxisCtrl"();
	 END_REGION

	 REGION Conveyor_Infeed
	     // 2026-05-20: palletizing infeed split out of FB_AutoCtrl_Palletizing
	     // (V4.0 -> V4.1). FB_ConveyorCtrl owns the box-spawn request
	     // (SpawnContainerCmd) and the conveyor belt (BeltVelocity). Active only
	     // in real mode (GDB_PalletizingCmd.bo_RequireSensorGate=TRUE); inert in
	     // phantom mode. Raw R_TRIG/F_TRIG/TON_TIME only -> zero OB91 impact.
	     "instFB_ConveyorCtrl"();
	 END_REGION

	 REGION Manual_Control
	     // Phase G (C67, 2026-05-18): manual-mode command routing.
	     // Gated internally on (GDB_ManualCmd.bo_Mode AND NOT
	     // GDB_MachineCmd.bo_Mode); inactive in AUTO mode.
	     // Placed AFTER Axis_Control so REGION 5 status mirror reads
	     // same-scan GDB_Control values (1-scan lag on Enable cmd is OK).
	     "instFB_ManualCtrl"();
	 END_REGION
	
	 REGION Auto_Cycle
	     // Wang Shuo 4-REGION pattern with single MC_MoveLinearAbsolute
	     // re-pulsing Execute per ABCDE step (6-state per source spec Â§3.3).
	   "instFB_AutoCtrl_ABCDE"();

	   // C69 Phase 2.2 (2026-05-18): palletizing 16-box 4-layer stacking
	   // demo. Same Wang Shuo 4-REGION pattern + same MC_MoveLinearAbsolute
	   // on ScaraArm3D. Mutex with ABCDE + Manual via bo_Mode gate inside
	   // FB_AutoCtrl_Palletizing REGION 2 (NOT GDB_MachineCmd.bo_Mode AND
	   // NOT GDB_ManualCmd.bo_Mode) prevents dual-master Execute pulses.
	   "instFB_AutoCtrl_Palletizing"();
	   
	     
	 END_REGION
	
	 REGION MCD_DataTransfer
	     // Publish ScaraArm3D.AxesData.A[i].{Position,Velocity} to GDB_MCDData
	     // for NX MCD signal-adapter consumption (V7 + V-OB91 gates).
	     "instFB_MCDDataTransfer"();
	 END_REGION

	 REGION HMI_Status_Mirror
	     // Phase 2.4 (C71, 2026-05-18): consolidate ~35 display tags from
	     // across the system into GDB_HMI_Status for HMI to bind to as a
	     // single read-only facade. Active-mode arbitration routes step +
	     // target XYZA from the correct cycle FB iDB. Placed LAST so all
	     // upstream FBs (AxisCtrl, ManualCtrl, AutoCtrl_ABCDE,
	     // AutoCtrl_Palletizing, MCDDataTransfer) have written their fresh
	     // state by the time this FB reads + mirrors them.
	     "instFB_HMIStatusMirror"();
	 END_REGION
	
	
END_ORGANIZATION_BLOCK

