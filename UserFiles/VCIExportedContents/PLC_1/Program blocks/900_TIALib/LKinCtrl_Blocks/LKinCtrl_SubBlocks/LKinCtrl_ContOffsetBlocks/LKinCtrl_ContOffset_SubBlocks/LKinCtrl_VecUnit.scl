	// Requirements: S7-1500/S7-1500T FW 2.5
	// Functionality: Create unit vector of coordinates (X, Y, Z) of "LKinCtrl_typeCOff3DPoint"
	//-----------------------------------------------------------------------------
	// Change log table:
	// Version  Date       Expert in charge Changes applied
	// 01.00.00 2018-08-27 SF               created
	//=============================================================================
	
	//Out = In/abs(In)
	#LKinCtrl_VecUnit := "LKinCtrl_VecDivScal"(vIn := #vIn,
	                                           sIn := "LKinCtrl_VecAbs"(#vIn));
	
	
END_FUNCTION

