	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_DEFINE_KIN_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterDefineKinZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
