	    REGION EXEC_DEFINE_WS_ZONE
	      IF #statStateMachine = #EXEC_DEFINE_WS_ZONE THEN
	        
	        // Reset instance
	        #instMC_DefineWSZone[#statFBCounterDefineWSZone](AxesGroup := #to_Kinematics,
	                                                         Execute := FALSE);
	        
	        IF #instMC_DefineWSZone[#statFBCounterDefineWSZone].Busy = FALSE THEN // Check if instance can be used
	          
	          // Define zone number to use
	          #tempCtr := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneConfigurationIndex;
	          
	          // Trigger instance
	          #instMC_DefineWSZone[#statFBCounterDefineWSZone](AxesGroup := #to_Kinematics,
	                                                           Execute := TRUE,
	                                                           ZoneType := #workspaceZones[#tempCtr].zoneType,
	                                                           ZoneNumber := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber,
	                                                           ReferenceSystem := #workspaceZones[#tempCtr].coordinateSystem,
	                                                           Frame := #workspaceZones[#tempCtr].frame,
	                                                           GeometryType := #workspaceZones[#tempCtr].geometryType,
	                                                           GeometryParameter := #workspaceZones[#tempCtr].geometryParameter);
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_DEFINE_WS_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterDefineWSZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set FBCounter variables
	          IF #statFBCounterDefineWSZone < #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_WS_ZONE THEN
	            #statFBCounterDefineWSZone := #statFBCounterDefineWSZone + 1;
	          ELSE
	            #statFBCounterDefineWSZone := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION EXEC_DEFINE_WS_ZONE
	    
	    REGION EXEC_ACTIVATE_WS_ZONE
	      IF #statStateMachine = #EXEC_ACTIVATE_WS_ZONE THEN
	        
	        // Reset instance
	        #instMC_ActivateWSZone[#statFBCounterActivateWSZone](AxesGroup := #to_Kinematics,
	                                                             Execute := FALSE);
	        
	        // 19.03.2021: Workaround as SetZoneActive is not added to motionQueue correctly
	        #tempCallOk := TRUE;
	        // Check if zone is going to be defined per command
	        IF #to_Kinematics.StatusWorkspaceZone[#pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber].Valid = FALSE THEN
	          FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_WS_ZONE DO
	            // Check if instance to define zone is busy and zone number matches
	            IF #instMC_DefineWSZone[#tempCtr].Busy
	              AND #instMC_DefineWSZone[#tempCtr].ZoneNumber = #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber
	            THEN
	              // Wait until the define command is done
	              #tempCallOk := FALSE;
	              EXIT;
	            END_IF;
	          END_FOR;
	        END_IF;
	        
	        IF #instMC_ActivateWSZone[#statFBCounterActivateWSZone].Busy = FALSE AND #tempCallOk THEN // Check if instance can be used
	          // Trigger instance
	          #instMC_ActivateWSZone[#statFBCounterActivateWSZone](AxesGroup := #to_Kinematics,
	                                                               Execute := TRUE,
	                                                               ZoneNumber := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber);
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_ACTIVATE_WS_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterActivateWSZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set FBCounter variables
	          IF #statFBCounterActivateWSZone < #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_WS_ZONE THEN
	            #statFBCounterActivateWSZone := #statFBCounterActivateWSZone + 1;
	          ELSE
	            #statFBCounterActivateWSZone := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION EXEC_ACTIVATE_WS_ZONE
	    
	    REGION EXEC_DEACTIVATE_WS_ZONE
	      IF #statStateMachine = #EXEC_DEACTIVATE_WS_ZONE THEN
	        
	        // Reset instance
	        #instMC_DeactivateWSZone[#statFBCounterDeactivateWSZone](AxesGroup := #to_Kinematics,
	                                                                 Execute := FALSE);
	        
	        IF #instMC_DeactivateWSZone[#statFBCounterDeactivateWSZone].Busy = FALSE THEN // Check if instance can be used
	          
	          // Always set zone number to valid index if deactivation mode is not specific
	          IF #pathDataElementPreBuf.cmdParameters.zoneParameters.deactivationMode <> "ZONE_DEACTIVATION_MODE_SPECIFIC" THEN
	            #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber := 1;
	          END_IF;
	          
	          // Trigger instance
	          #instMC_DeactivateWSZone[#statFBCounterDeactivateWSZone](AxesGroup := #to_Kinematics,
	                                                                   Execute := TRUE,
	                                                                   ZoneNumber := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber,
	                                                                   Mode := #pathDataElementPreBuf.cmdParameters.zoneParameters.deactivationMode);
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_DEACTIVATE_WS_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterDeactivateWSZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set FBCounter variables
	          IF #statFBCounterDeactivateWSZone < #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_WS_ZONE THEN
	            #statFBCounterDeactivateWSZone := #statFBCounterDeactivateWSZone + 1;
	          ELSE
	            #statFBCounterDeactivateWSZone := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION EXEC_DEACTIVATE_WS_ZONE
	    
