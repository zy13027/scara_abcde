	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_DeactivateWSZone[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                            Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_DEFINE_KIN_ZONE":
	          REGION DEFINE_KIN_ZONE
	            // set state to signalize configuration command running
