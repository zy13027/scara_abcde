	            END_IF;
	            
	            // Call instance to update outputs
	            #instMC_DefineWSZone[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_DefineWSZone[#tempActiveInstance].#Done;
	            //#statActive := #instMC_DefineWSZone[#tempActiveInstance].Busy OR #tempCmdDone;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_DefineWSZone[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_DefineWSZone[#tempActiveInstance].ErrorId <> 16#80CD THEN
	                #statStatus := #ERR_DEFINEWSZONE_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_DefineWSZone[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
