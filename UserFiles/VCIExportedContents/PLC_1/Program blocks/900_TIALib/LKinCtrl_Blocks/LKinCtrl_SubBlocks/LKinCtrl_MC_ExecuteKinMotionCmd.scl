	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Call instance
	            #instMC_DefineKinZone[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_DefineKinZone[#tempActiveInstance].#Done;
	            //#statActive := #instMC_DefineKinZone[#tempActiveInstance].Busy OR #tempCmdDone;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_DefineKinZone[#tempActiveInstance].Error THEN
