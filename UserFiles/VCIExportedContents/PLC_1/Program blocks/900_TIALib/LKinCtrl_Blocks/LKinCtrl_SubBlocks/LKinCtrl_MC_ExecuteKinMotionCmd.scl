	        END_IF;
	      END_IF;
	    END_REGION EXEC_DEFINE_KIN_ZONE
	    
	    REGION EXEC_ACTIVATE_KIN_ZONE
	      IF #statStateMachine = #EXEC_ACTIVATE_KIN_ZONE THEN
	        
	        // Reset instance
	        #instMC_ActivateKinZone[#statFBCounterActivateKinZone](AxesGroup := #to_Kinematics,
	                                                               Execute := FALSE);
	        
	        // 19.03.2021: Workaround as SetZoneActive is not added to motionQueue correctly
	        #tempCallOk := TRUE;
	        // Check if zone is going to be defined per command
	        IF #to_Kinematics.StatusWorkspaceZone[#pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber].Valid = FALSE THEN
	          FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_WS_ZONE DO
	            // Check if instance to define zone is busy and zone number matches
	            IF #instMC_DefineWSZone[#tempCtr].Busy
	              AND #instMC_DefineWSZone[#tempCtr].ZoneNumber = #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber
	            THEN
	              // Wait until the define command is done
	              #tempCallOk := FALSE;
	              EXIT;
	            END_IF;
	          END_FOR;
	        END_IF;
	        
	        IF #instMC_ActivateKinZone[#statFBCounterActivateKinZone].Busy = FALSE AND #tempCallOk THEN // Check if instance can be used
	          // Trigger instance
	          #instMC_ActivateKinZone[#statFBCounterActivateKinZone](AxesGroup := #to_Kinematics,
	                                                                 Execute := TRUE,
	                                                                 ZoneNumber := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber);
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_ACTIVATE_KIN_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterActivateKinZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set FBCounter variables
	          IF #statFBCounterActivateKinZone < #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_KIN_ZONE THEN
	            #statFBCounterActivateKinZone := #statFBCounterActivateKinZone + 1;
	          ELSE
	            #statFBCounterActivateKinZone := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION EXEC_ACTIVATE_KIN_ZONE
	    
	    REGION EXEC_DEACTIVATE_KIN_ZONE
	      IF #statStateMachine = #EXEC_DEACTIVATE_KIN_ZONE THEN
	        
	        // Reset instance
	        #instMC_DeactivateKinZone[#statFBCounterDeactivateKinZone](AxesGroup := #to_Kinematics,
	                                                                   Execute := FALSE);
	        
	        IF #instMC_DeactivateKinZone[#statFBCounterDeactivateKinZone].Busy = FALSE THEN // Check if instance can be used
	          // Always set zone number to valid index if deactivation mode is not specific
	          IF #pathDataElementPreBuf.cmdParameters.zoneParameters.deactivationMode <> "ZONE_DEACTIVATION_MODE_SPECIFIC" THEN
	            #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber := 2;
	          END_IF;
	          
	          // Trigger instance
	          #instMC_DeactivateKinZone[#statFBCounterDeactivateKinZone](AxesGroup := #to_Kinematics,
	                                                                     Execute := TRUE,
	                                                                     ZoneNumber := #pathDataElementPreBuf.cmdParameters.zoneParameters.zoneNumber,
	                                                                     Mode := #pathDataElementPreBuf.cmdParameters.zoneParameters.deactivationMode);
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_DEACTIVATE_KIN_ZONE";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := #statFBCounterDeactivateKinZone;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set FBCounter variables
	          IF #statFBCounterDeactivateKinZone < #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_KIN_ZONE THEN
	            #statFBCounterDeactivateKinZone := #statFBCounterDeactivateKinZone + 1;
	          ELSE
	            #statFBCounterDeactivateKinZone := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION EXEC_DEACTIVATE_KIN_ZONE
	    
	    REGION EXEC_FLAG_ONLY
	      IF #statStateMachine = #EXEC_FLAG_ONLY
	        // AND #statDebugState = TRUE
	      THEN
	        // reset  variable for single step debugging of states
	        #statDebugState := FALSE;
	        
	        // command details from PathData and assignment to MC_FBs for activeCmdNo
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_CMD_FLAG_ONLY";
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := 0;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	        #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	        
	        // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	        IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	          #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	        ELSE
	          #statStoreExecuteBuffer.writeBufferElement := 1;
	        END_IF;
	        
	        // set status for outputs
	        #statStatus := #STATUS_CMD_EXECUTED;
	      END_IF;
	    END_REGION EXEC_FLAG_ONLY
	    
	    REGION EXEC_WAIT_TIME
	      IF #statStateMachine = #EXEC_WAIT_TIME
	        // AND #statDebugState = TRUE
	      THEN
	        // reset  variable for single step debugging of states
	        #statDebugState := FALSE;
	        
	        // Signalize to halt execution of further commands
	        #statPauseCmdExecution := TRUE;
	        
	        // Reset timer
	        #instWaitTime(IN := FALSE,
	                      PT := #statWaitTime);
	        
	        // set execute trigger to run timer
	        #statExecWaitTime := TRUE;
	        // read wait time - duration [ms]
	        #statWaitTime := UDINT_TO_TIME(LREAL_TO_UDINT(#pathDataElementPreBuf.cmdParameters.pathDynamics.velocity));
	        
	        // command details from PathData and assignment to MC_FBs for activeCmdNo
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_CMD_WAIT_TIME";
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := 0;
	        #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	        #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	        
	        // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	        IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	          #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	        ELSE
	          #statStoreExecuteBuffer.writeBufferElement := 1;
	        END_IF;
	        
	        // set status for outputs
	        #statStatus := #STATUS_CMD_EXECUTED;
	      END_IF;
	    END_REGION EXEC_WAIT_TIME
	    
	    REGION EXEC_SET_TOOL
	      IF #statStateMachine = #EXEC_SET_TOOL THEN
	        
	        // Reset instance
	        #instMC_SetTool(AxesGroup := #to_Kinematics,
	                        Execute := FALSE);
	        
	        IF #instMC_SetTool.Busy = FALSE THEN // Check if instance can be used
	          #statPauseCmdExecution := TRUE; // Pause execution 
	          // Store toolnumber here but do not trigger 
	          #instMC_SetTool.ToolNumber := #pathDataElementPreBuf.cmdParameters.toolNumber;
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_ACTIVATE_TOOL";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := 0;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	        
	      END_IF;
	    END_REGION EXEC_SET_TOOL
	    
	    REGION EXEC_DEFINE_TOOL
	      IF #statStateMachine = #EXEC_DEFINE_TOOL THEN
	        // Reset instance
	        #instMC_DefineTool(AxesGroup := #to_Kinematics,
	                           Execute := FALSE);
	        
	        IF #instMC_DefineTool.Busy = FALSE THEN // Check if instance can be used
	          #statPauseCmdExecution := TRUE; // Pause execution 
	          
	          // Set tool frame
	          #instMC_DefineTool.Frame.x := #pathDataElementPreBuf.cmdCoordinates.targetPosition[1];
	          #instMC_DefineTool.Frame.y := #pathDataElementPreBuf.cmdCoordinates.targetPosition[2];
	          #instMC_DefineTool.Frame.z := #pathDataElementPreBuf.cmdCoordinates.targetPosition[3];
	          #instMC_DefineTool.Frame.a := #pathDataElementPreBuf.cmdCoordinates.targetPosition[4];
	          #instMC_DefineTool.Frame.b := #pathDataElementPreBuf.cmdCoordinates.targetPosition[5];
	          #instMC_DefineTool.Frame.c := #pathDataElementPreBuf.cmdCoordinates.targetPosition[6];
	          
	          // command details from PathData and assignment to MC_FBs for activeCmdNo
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataName := #pathDataElementPreBuf.pathDataName;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].pathDataIdentifier := #pathDataElementPreBuf.pathDataIdentifier;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].setNumber := #pathDataElementPreBuf.cmdID;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionType := "LKINCTRL_MC_SET_TOOL_FRAME";
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].MotionFBNo := 0;
	          #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.writeBufferElement].measurementCmd := #pathDataElementPreBuf.measurementCmd;
	          #statStoreExecuteBuffer.lastBufferElement := #statStoreExecuteBuffer.writeBufferElement;
	          
	          // increase writeBufferElement pointer for statStoreBuffer for assignment of activeCmdNo
	          IF #statStoreExecuteBuffer.writeBufferElement < #LKINCTRL_EXECUTEBUFFER_LENGTH THEN
	            #statStoreExecuteBuffer.writeBufferElement := #statStoreExecuteBuffer.writeBufferElement + 1;
	          ELSE
	            #statStoreExecuteBuffer.writeBufferElement := 1;
	          END_IF;
	          
	          // set status for outputs
	          #statStatus := #STATUS_CMD_EXECUTED;
	        END_IF;
	      END_IF;
	    END_REGION
	    
	  END_REGION COMMAND_EXECUTION
	  
	  // state reached when GroupInterrupt is interrupted ==> do nothing when interrupted
	  REGION CONTINUEING 
	    IF #statStateMachine = #CONTINUEING
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // FR 12.10.2021
	      // Check if interrupt is running 
	      IF #instMC_GroupInterrupt.Busy THEN
	        // Wait for interrupt done 
	        ;
	      ELSIF #instMC_GroupInterrupt.Done THEN
	        // Reset execute of intterupt
	        #statExecGroupInterrupt := FALSE;
	        // Execute continue
	        // Note: Execute directly here. Seems to work with the instances. Avoid case, that "interrupting" state will not get a "interrupt.done" signal if it is set in next cycle
	        #statExecGroupContinue := TRUE;
	      ELSIF #tempKinematicsStatusWord.%X17 = TRUE THEN
	        // Execute continue
	        #statExecGroupContinue := TRUE;
	      ELSE
	        // Execute continue
	        #statExecGroupContinue := TRUE;
	      END_IF;
	      
	      IF #instMC_GroupContinue.Done THEN
	        // Check if any motion is active at the Kinematics
	        IF #tempKinematicsStatusWord.%X8
	          OR #tempKinematicsStatusWord.%X9
	          OR #tempKinematicsStatusWord.%X11
	        THEN
	          IF #to_Kinematics.TcpInWcs.x.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.y.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.z.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.a.Velocity <> 0.0
	          THEN
	            // Workaround to wait until pathVelocity > 0 
	            // Continue done
	            #statStateMachine := #CONTINUED;
	          ELSE
	            ; // Wait until pathVelo is > 0.0
	          END_IF;
	        ELSE
	          // Continue done
	          #statStateMachine := #CONTINUED;
	        END_IF;
	      ELSE
	        // Wait for done
	        ;
	      END_IF;
	      
	    END_IF;
	  END_REGION CONTINUEING
	  
	  // state reached when GroupContinue is done ==> do nothing when path motion continues
	  REGION CONTINUED
	    IF #statStateMachine = #CONTINUED
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // Set status and reset continue execute
	      #statStatus := #STATUS_PATHMOTION_RUNNING;
	      #statExecGroupContinue := FALSE;
	      
	      // FR 11.03.2020: Continue during waitTime --> Start timer again
	      IF #statWaitTimeActive THEN
	        #statExecWaitTime := TRUE;
	      END_IF;
	      
	    END_IF;
	  END_REGION MOTION_CONTINUED
	  
	  // state reached to execute MC_GroupInterrupt ==> wait for interrupt to be done
	  REGION INTERRUPTING
	    IF #statStateMachine = #INTERRUPTING
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // FR 11.03.2020: Interrupt during waitTime --> Save remaining time and stop timer
	      IF #statWaitTimeActive AND #statExecWaitTime THEN
	        #statWaitTime := #instWaitTime.PT - #instWaitTime.ET;
	        #statExecWaitTime := FALSE;
	      END_IF;
	      
	      // FR 12.10.2021:
	      // Check if continue is running 
	      IF #instMC_GroupContinue.Busy THEN
	        // Wait for continue done 
	        ;
	      ELSIF #instMC_GroupContinue.Done THEN
	        // Wait here until kinematic status word false (not interrupted)
	        
	        // Check if any motion is active at the Kinematics
	        IF #tempKinematicsStatusWord.%X8
	          OR #tempKinematicsStatusWord.%X9
	          OR #tempKinematicsStatusWord.%X11
	        THEN
	          IF #to_Kinematics.TcpInWcs.x.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.y.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.z.Velocity <> 0.0
	            OR #to_Kinematics.TcpInWcs.a.Velocity <> 0.0
	          THEN
	            // Workaround to wait until pathVelocity > 0 
	            // Execute interrupt
	            #statExecGroupInterrupt := TRUE;
	            #statExecGroupContinue := FALSE;
	          ELSE
	            ; // Wait until pathVelo is > 0.0
	          END_IF;
	        ELSE
	          // Execute interrupt directly here. Seems to work with the instances.
	          IF #tempKinematicsStatusWord.%X17 = FALSE THEN
	            // Execute interrupt
	            #statExecGroupInterrupt := TRUE;
	            #statExecGroupContinue := FALSE;
	          END_IF;
	        END_IF;
	        
	      ELSIF #tempKinematicsStatusWord.%X17 = FALSE THEN
	        // Execute interrupt
	        #statExecGroupInterrupt := TRUE;
	        
	      ELSIF #instMC_GroupInterrupt.Busy THEN
	        // Wait until interrupt done
	        ;
	      ELSIF #instMC_GroupInterrupt.Active THEN
	        // Wait until interrupt done
	        ;
	      ELSIF #instMC_GroupInterrupt.Done THEN
	        // is handled below
	        ;
	      ELSIF #instMC_GroupInterrupt.CommandAborted THEN
	        // Reset interrupt execute
	        #statExecGroupInterrupt := FALSE;
	      ELSE
	        // Wait till continue busy/done or statusword X17 switches to False in order to interrupt again?
	        #statExecGroupInterrupt := TRUE;
	      END_IF;
	      
	      IF #instMC_GroupInterrupt.Done THEN
	        // Interrupt done
	        #statStateMachine := #INTERRUPTED;
	      ELSE
	        // Wait for interrupt done
	        ;
	      END_IF;
	      
	    END_IF;
	  END_REGION INTERRUPTING
	  
	  // state reached when GroupInterrupt is done ==> do nothing when interrupted
	  REGION INTERRUPTED
	    IF #statStateMachine = #INTERRUPTED
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // Set status and reset interrupt execute
	      #statStatus := #STATUS_PATHMOTION_INTERRUPTED;
	      #statExecGroupInterrupt := FALSE;
	    END_IF;
	  END_REGION INTERRUPTED
	  
	  // state reached to execute MC_GroupStop ==> wait for stop to be done
	  REGION STOPPING
	    IF #statStateMachine = #STOPPING
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // reset all execute triggers of motion commands
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_LIN DO
	        #instMC_MoveLinAbs[#tempCtr].Execute := FALSE;
	        #instMC_MoveLinRel[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_CIRC DO
	        #instMC_MoveCircAbs[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_MOVEDIRECT DO
	        #instMC_MoveDirectAbs[#tempCtr].Execute := FALSE;
	        #instMC_MoveDirectRel[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_TRACKCONV DO
	        #instMC_TrackConveyor[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_SETOCS DO
	        #instMC_SetOCS[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_WS_ZONE DO
	        #instMC_DefineWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_WS_ZONE DO
	        #instMC_ActivateWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_WS_ZONE DO
	        #instMC_DeactivateWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_KIN_ZONE DO
	        #instMC_DefineKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_KIN_ZONE DO
	        #instMC_ActivateKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_KIN_ZONE DO
	        #instMC_DeactivateKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_LIN_PNP DO
	        //Call instance to handle correct block execution
	        #instMC_MovePickAndPlaceLinear[#tempCtr](execute := FALSE,
	                                                 axesGroup := #to_Kinematics);
	      END_FOR;
	      
	      // Deactivate waitTime
	      #statExecWaitTime := FALSE;
	      #statWaitTime := t#0s;
	      // Deactivate tool commands
	      #instMC_SetTool.Execute := FALSE;
	      #instMC_DefineTool.Execute := FALSE;
	      // Reset execute of Interrupt/Continue
	      #statExecGroupContinue := FALSE;
	      #statExecGroupInterrupt := FALSE;
	      
	      // set status accordingly
	      #statStatus := #STATUS_PATHMOTION_STOPPING;
	      
	      IF #statExternalStopDetected = FALSE THEN
	        // handle usual internal stop reaction
	        IF #instMC_GroupStop.Busy = FALSE AND #instMC_GroupStop.CommandAborted = FALSE THEN
	          // check TO Kinematics to have stopped successfully
	          IF (#tempKinematicsStatusWord.%X12 = TRUE)                        // TO Kinematics with constant velocity
	            AND (#tempStatusPathVelo = 0.0)                                 // TO Kinematics path velocity 0.0
	            AND (#tempMotionQueueCommands = 0)                              // MotionQueue deleted completely
	            AND (#instMC_GroupStop.Done = TRUE)
	          THEN
	            #statStateMachine := #STOPPED_STATE;
	          ELSE
	            // set execute trigger for MC_GroupStop
	            #statExecGroupStop := TRUE;
	          END_IF;
	        ELSE
	          // Added FR: 08.04.2019
	          // stop conditions fulfilled without GroupStop executed successfully (done <> TRUE, busy = TRUE)
	          IF (#tempKinematicsStatusWord.%X12 = TRUE)                        // TO Kinematics with constant velocity
	            AND (#tempKinematicsStatusWord.%X6 = TRUE)                      // no jobs active on TO Kinematics
	            AND (#tempKinematicsStatusWord.%X16 = FALSE)                    // TO Kinematics not stopping anymore ==> GroupStop done
	            AND (#tempStatusPathVelo = 0.0)                                 // TO Kinematics path velocity 0.0
	            AND (#tempMotionQueueCommands = 0)                              // MotionQueue deleted completely
	          THEN
	            #statStateMachine := #STOPPED_STATE;
	          END_IF;
	        END_IF;
	        
	      ELSE
	        // handle external stop
	        IF (#tempKinematicsStatusWord.%X12 = TRUE)                        // TO Kinematics with constant velocity
	          AND (#tempKinematicsStatusWord.%X6 = TRUE)                      // no jobs active on TO Kinematics
	          AND (#tempKinematicsStatusWord.%X16 = FALSE)                    // TO Kinematics not stopping anymore ==> GroupStop done
	          AND (#tempStatusPathVelo = 0.0)                                 // TO Kinematics path velocity 0.0
	          AND (#tempMotionQueueCommands = 0)                              // MotionQueue deleted completely
	        THEN
	          #statStateMachine := #STOPPED_STATE;
	          // reset bit for detection of external stop triggered
	          #statExternalStopDetected := FALSE;
	        END_IF;
	      END_IF;
	      
	    END_IF;
	    
	  END_REGION STOPPING
	  
	  // state reached when GroupStop is executed ==> do nothing when stopped
	  REGION STOPPED_STATE
	    IF #statStateMachine = #STOPPED_STATE
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // Remove execute from GroupStop
	      #statExecGroupStop := FALSE;
	      
	      // check for MC_GroupStop to be finished or inactive
	      IF (#instMC_GroupStop.Busy = FALSE AND #tempKinematicsStatusWord.%X16 = FALSE) THEN
	          #statStatus := #STATUS_COMMAND_ABORTED;
	      END_IF;
	      
	      // Check stopMode if desync from conveyor shall be executed
	      IF (#tempStopMode = 10 OR #tempStopMode = 11) AND #statActualTrackedOCS <> 0 THEN
	        #statStateMachine := #DESYNC_CONVEYOR;
	        #statStatus := #STATUS_DESYNC_CONVEYOR;
	        // Call linear cmd to reset
	        #instMC_MoveLinAbs[#statFBCounterLinAbs](AxesGroup := #to_Kinematics,
	                                                 Execute := FALSE);
	        
	      END_IF;
	      
	    END_IF;
	  END_REGION STOPPED_STATE
	  
	  REGION STOP_DESYNC_CONVEYOR
	    IF #statStateMachine = #DESYNC_CONVEYOR
	      // AND #statDebugState = TRUE
	    THEN
	      // Check if linear cmd is done or not busy anymore
	      IF #instMC_MoveLinAbs[#statFBCounterLinAbs].Done
	        OR #instMC_MoveLinAbs[#statFBCounterLinAbs].Error
	        OR (#instMC_MoveLinAbs[#statFBCounterLinAbs].Busy = FALSE
	        AND #instMC_MoveLinAbs[#statFBCounterLinAbs].Execute = TRUE)
	      THEN
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Execute := FALSE;
	        #statStatus := #STATUS_COMMAND_ABORTED;
	      END_IF;
	      
	      // Check if stop is not active at kinematics --> Linear cmd is not rejected
	      IF #tempKinematicsStatusWord.%X16 = FALSE AND #statStatus <> #STATUS_COMMAND_ABORTED THEN
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[1] := #to_Kinematics.TcpInWcs.x.Position;
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[2] := #to_Kinematics.TcpInWcs.y.Position;
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[3] := #to_Kinematics.TcpInWcs.z.Position;
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[4] := #to_Kinematics.TcpInWcs.a.Position;
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[5] := #to_Kinematics.TcpInWcs.b.Position;
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Position[6] := #to_Kinematics.TcpInWcs.c.Position;
	        
	        // Execute linear cmd in wcs
	        #instMC_MoveLinAbs[#statFBCounterLinAbs].Execute := TRUE;
	      END_IF;
	      
	      // Execute linear cmd in wcs
	      #instMC_MoveLinAbs[#statFBCounterLinAbs](AxesGroup := #to_Kinematics,
	                                               //Execute := TRUE,
	                                               //Position is written above
	                                               Velocity := -1,
	                                               Acceleration := -1,
	                                               Deceleration := -1,
	                                               Jerk := -1,
	                                               DirectionA := 3, // shortest
	                                               CoordSystem := 0, // WCS
	                                               BufferMode := 1, // No blending
	                                               DynamicAdaption := 0); // DA must be off
	      
	    END_IF;
	  END_REGION STOP_DESYNC_CONVEYOR
	  
	  // state reached when error occured ==> do nothing when error occured
	  REGION ERROR_STATE
	    IF #statStateMachine = #ERROR_STATE
	      // AND #statDebugState = TRUE
	    THEN
	      // reset  variable for single step debugging of states
	      #statDebugState := FALSE;
	      
	      // reset all execute triggers of motion commands
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_LIN DO
	        #instMC_MoveLinAbs[#tempCtr].Execute := FALSE;
	        #instMC_MoveLinRel[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_CIRC DO
	        #instMC_MoveCircAbs[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_MOVEDIRECT DO
	        #instMC_MoveDirectAbs[#tempCtr].Execute := FALSE;
	        #instMC_MoveDirectRel[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_TRACKCONV DO
	        #instMC_TrackConveyor[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_SETOCS DO
	        #instMC_SetOCS[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_WS_ZONE DO
	        #instMC_DefineWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_WS_ZONE DO
	        #instMC_ActivateWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_WS_ZONE DO
	        #instMC_DeactivateWSZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEFINE_KIN_ZONE DO
	        #instMC_DefineKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_ACTIVATE_KIN_ZONE DO
	        #instMC_ActivateKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_DEACTIVATE_KIN_ZONE DO
	        #instMC_DeactivateKinZone[#tempCtr].Execute := FALSE;
	      END_FOR;
	      FOR #tempCtr := 1 TO #LKINCTRL_MAX_NUMBER_OF_CMDS_LIN_PNP DO
	        //Call instance to handle correct block execution
	        #instMC_MovePickAndPlaceLinear[#tempCtr](execute := FALSE,
	                                                 axesGroup := #to_Kinematics);
	      END_FOR;
	      
	      // Deactivate waitTime
	      #statExecWaitTime := FALSE;
	      #statWaitTime := t#0s;
	      // Deactivate tool commands
	      #instMC_SetTool.Execute := FALSE;
	      #instMC_DefineTool.Execute := FALSE;
	      
	      // Reset execute of Interrupt/Continue
	      #statExecGroupContinue := FALSE;
	      #statExecGroupInterrupt := FALSE;
	    END_IF;
	    
	    
	  END_REGION ERROR_STATE
	  
	END_REGION STATE_MACHINE
	
	REGION CALL_ACTIVE_COMMAND
	  //----------------------------------------------------------------------------------------------
	  // FB Execution & Analysis
	  //----------------------------------------------------------------------------------------------
	  REPEAT
	    // Reset repeat condition
	    #tempRepeat := FALSE;
	    
	    // Only check finished cmds if FB is still busy & commands shall be executed
	    IF #statBusy
	      AND #statStatus.%X15 = FALSE
	      AND #statStatus <> #STATUS_COMMAND_ABORTED
	    THEN
	      // check to_kinematics to reset active
	      IF #tempKinematicsStatusWord.%X8 = FALSE
	        AND #tempKinematicsStatusWord.%X9 = FALSE
	        AND #tempKinematicsStatusWord.%X11 = FALSE
	      THEN
	        // reset active output
	        #statActive := FALSE;
	      END_IF;
	      
	      // Init temporary variables
	      #tempCmdDone := FALSE;
	      #tempActiveInstance := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].MotionFBNo;
	      #tempCmdType := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].MotionType;
	      #statIsMeasurementCmd := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].measurementCmd;
	      
	      
	      // Reset debug variables
	      #statDebugMessage := '';
	      #statDebugFaultyValue := 0;
	      
	      //----------------------------------------------------------------------------------------------
	      // Call active command to update status
	      //----------------------------------------------------------------------------------------------
	      CASE #tempCmdType OF
	        "LKINCTRL_CMD_FLAG_ONLY": // FlagOnly
	          REGION FLAG_ONLY
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            // check for flagOnly command to have been 'executed' (activeCmdNo has been written to output for at least one cycle)
	            // eventually replace by this
	            IF #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber = #writtenActiveCmdNo THEN
	              #tempCmdDone := TRUE;
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVELINEARABS":  // Linear
	          REGION LINEAR_ABS
	            // Call instance to update outputs
	            #instMC_MoveLinAbs[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MoveLinAbs[#tempActiveInstance].#Done;
	            #statActive := #instMC_MoveLinAbs[#tempActiveInstance].Active OR #tempCmdDone;
	            #statRemainingDistance := #instMC_MoveLinAbs[#tempActiveInstance].RemainingDistance;
	            
	            IF #instMC_MoveLinAbs[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MoveLinAbs[#tempActiveInstance].ErrorId <> 16#80CD
	                AND #statStatus <> #STATUS_PATHMOTION_STOPPING
	              THEN
	                #statStatus := #ERR_LINEAR_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MoveLinAbs[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MoveLinAbs[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                      Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVELINEARREL":  // Linear
	          REGION LINEAR_REL
	            // Call instance to update outputs
	            #instMC_MoveLinRel[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MoveLinRel[#tempActiveInstance].#Done;
	            #statActive := #instMC_MoveLinRel[#tempActiveInstance].Active OR #tempCmdDone;
	            #statRemainingDistance := #instMC_MoveLinRel[#tempActiveInstance].RemainingDistance;
	            
	            IF #instMC_MoveLinRel[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MoveLinRel[#tempActiveInstance].ErrorId <> 16#80CD
	                AND #statStatus <> #STATUS_PATHMOTION_STOPPING
	              THEN
	                #statStatus := #ERR_LINEAR_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MoveLinRel[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MoveLinRel[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                      Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVECIRCULARABS":  // Circular
	          REGION CIRCULAR
	            // Call instance to update outputs
	            #instMC_MoveCircAbs[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MoveCircAbs[#tempActiveInstance].#Done;
	            #statActive := #instMC_MoveCircAbs[#tempActiveInstance].Active OR #tempCmdDone;
	            #statRemainingDistance := #instMC_MoveCircAbs[#tempActiveInstance].RemainingDistance;
	            
	            IF #instMC_MoveCircAbs[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MoveCircAbs[#tempActiveInstance].ErrorId <> 16#80CD
	                AND #statStatus <> #STATUS_PATHMOTION_STOPPING
	              THEN
	                #statStatus := #ERR_CIRCULAR_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MoveCircAbs[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MoveCircAbs[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                       Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVEDIRECTABS": // MoveDirect
	          REGION MOVE_DIRECT_ABS
	            // Call instance to update outputs
	            #instMC_MoveDirectAbs[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MoveDirectAbs[#tempActiveInstance].#Done;
	            #statActive := #instMC_MoveDirectAbs[#tempActiveInstance].Active OR #tempCmdDone;
	            
	            CASE "LKINCTRL_SPTP_EXECUTION_STATUS_OUTPUT" OF
	              0: // Regular execution time status
	                #statRemainingDistance := #instMC_MoveDirectAbs[#tempActiveInstance].ExecutionTimeStatus;
	              1:  // Inverted execution time status
	                #statRemainingDistance := 1.0 - #instMC_MoveDirectAbs[#tempActiveInstance].ExecutionTimeStatus; // inverted output
	              2: // Approximate cartesian distance
	                #instCalcRemainingDist(writeCmdLoggerElement := #statStoreExecuteBuffer.writeBufferElement,
	                                       activeCmdLoggerElement := #statStoreExecuteBuffer.activeBufferElement,
	                                       remainingDistance => #statRemainingDistance,
	                                       loggerElements := #statStoreExecuteBuffer.bufferElement,
	                                       OCSFrames := #statOCSFrames,
	                                       userFrames := #statUserFrames,
	                                       toKinematics := #to_Kinematics);
	                
	              ELSE
	                // Regular execution time status
	                #statRemainingDistance := #instMC_MoveDirectAbs[#tempActiveInstance].ExecutionTimeStatus;
	            END_CASE;
	            
	            IF #instMC_MoveDirectAbs[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MoveDirectAbs[#tempActiveInstance].ErrorId <> 16#80CD THEN
	                #statStatus := #ERR_MOVEDIRECT_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MoveDirectAbs[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MoveDirectAbs[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                         Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVEDIRECTREL": // MoveDirect
	          REGION MOVE_DIRECT_REL
	            // Call instance to update outputs
	            #instMC_MoveDirectRel[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MoveDirectRel[#tempActiveInstance].#Done;
	            #statActive := #instMC_MoveDirectRel[#tempActiveInstance].Active OR #tempCmdDone;
	            
	            CASE "LKINCTRL_SPTP_EXECUTION_STATUS_OUTPUT" OF
	              0: // Regular execution time status
	                #statRemainingDistance := #instMC_MoveDirectRel[#tempActiveInstance].ExecutionTimeStatus;
	              1:  // Inverted execution time status
	                #statRemainingDistance := 1.0 - #instMC_MoveDirectRel[#tempActiveInstance].ExecutionTimeStatus; // inverted output
	              2: // Approximate cartesian distance
	                #instCalcRemainingDist(writeCmdLoggerElement := #statStoreExecuteBuffer.writeBufferElement,
	                                       activeCmdLoggerElement := #statStoreExecuteBuffer.activeBufferElement,
	                                       remainingDistance => #statRemainingDistance,
	                                       loggerElements := #statStoreExecuteBuffer.bufferElement,
	                                       OCSFrames := #statOCSFrames,
	                                       userFrames := #statUserFrames,
	                                       toKinematics := #to_Kinematics);
	              ELSE
	                // Regular execution time status
	                #statRemainingDistance := #instMC_MoveDirectRel[#tempActiveInstance].ExecutionTimeStatus;
	            END_CASE;
	            
	            IF #instMC_MoveDirectRel[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MoveDirectRel[#tempActiveInstance].ErrorId <> 16#80CD THEN
	                #statStatus := #ERR_MOVEDIRECT_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MoveDirectRel[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MoveDirectRel[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                         Execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_TRACKCONVEYORBELT":
	          REGION TRACK_CONVEYOR
	            // Call instance depending on axis type to update outputs
	            "LKinCtrl_CallMC_TrackConv"(axis := #statConveyorBeltAxis[#tempActiveInstance],
	                                        axesGroup := #to_Kinematics,
	                                        instTrackConveyorBelt := #instMC_TrackConveyor[#tempActiveInstance]);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_TrackConveyor[#tempActiveInstance].#Done; // Either cmd is done or tracking state is changed
	            #tempCmdDone := #tempCmdDone OR #to_Kinematics.StatusConveyor[#instMC_TrackConveyor[#tempActiveInstance].CoordSystem].TrackingState >= 1;
	            //#statActive := #instMC_TrackConveyor[#tempActiveInstance].Busy OR #tempCmdDone;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_TrackConveyor[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_TrackConveyor[#tempActiveInstance].ErrorId <> 16#80CD THEN
	                #statStatus := #ERR_TRACKCONVEYOR_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_TrackConveyor[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_TrackConveyor[#tempActiveInstance].Execute := FALSE;
	              "LKinCtrl_CallMC_TrackConv"(axis := #statConveyorBeltAxis[#tempActiveInstance],
	                                          axesGroup := #to_Kinematics,
	                                          instTrackConveyorBelt := #instMC_TrackConveyor[#tempActiveInstance]);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_MOVELINEARPICKANDPLACE":
	          REGION PICK_AND_PLACE_LINEAR
	            // Call instance to update outputs
	            #instMC_MovePickAndPlaceLinear[#tempActiveInstance](axesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_MovePickAndPlaceLinear[#tempActiveInstance].#done;
	            #statActive := #instMC_MovePickAndPlaceLinear[#tempActiveInstance].active OR #tempCmdDone;
	            #statRemainingDistance := #instMC_MovePickAndPlaceLinear[#tempActiveInstance].remainingPathLength;
	            
	            IF #instMC_MovePickAndPlaceLinear[#tempActiveInstance].error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_MovePickAndPlaceLinear[#tempActiveInstance].diagnostics.subFunctionStatus <> 16#80CD
	                AND #statStatus <> #STATUS_PATHMOTION_STOPPING
	              THEN
	                #statStatus := #ERR_LINEARPICKANDPLACE_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_MovePickAndPlaceLinear[#tempActiveInstance].status;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_MovePickAndPlaceLinear[#tempActiveInstance](axesGroup := #to_Kinematics,
	                                                                  execute := FALSE);
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_CMD_WAIT_TIME": // WaitTime
	          REGION WAIT_TIME
	            // call WAIT_TIME
	            #instWaitTime(IN := #statExecWaitTime,
	                          PT := #statWaitTime);
	            
	            // Check outputs
	            #tempCmdDone := #instWaitTime.Q;
	            #statActive := FALSE; // Always reset active
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #statExecWaitTime THEN
	              // Set waitTimeActive for check if interrupting
	              #statWaitTimeActive := TRUE;
	              #statRemainingDistance := TIME_TO_UDINT(#statWaitTime - #instWaitTime.ET);
	            END_IF;
	            
	            // Check if wait time is done
	            IF #tempCmdDone THEN
	              #instWaitTime(IN := FALSE,
	                            PT := #statWaitTime);
	              
	              #statExecWaitTime := FALSE; // reset trigger when timer is done
	              #statWaitTimeActive := FALSE; // reset wait time active
	              #statPauseCmdExecution := FALSE;
	              #statRemainingDistance := 0.0; // Set remainingDistance to 0.0 if done --> sometimes 1 would still appear because of dataType conversion error
	            END_IF;
	            
	          END_REGION
	          
	        "LKINCTRL_MC_SET_OCS_FRAME":
	          REGION SET_OCS_FRAME
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Call instance to update outputs
	            #instMC_SetOCS[#tempActiveInstance](AxesGroup := #to_Kinematics);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_SetOCS[#tempActiveInstance].Done;
	            //#statActive := #tempCmdDone OR #instMC_SetOCS[#tempActiveInstance].Busy;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_SetOCS[#tempActiveInstance].Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              IF #instMC_SetOCS[#tempActiveInstance].ErrorId <> 16#80CD THEN
	                #statStatus := #ERR_SETOCS_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_SetOCS[#tempActiveInstance].ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_SetOCS[#tempActiveInstance](AxesGroup := #to_Kinematics,
	                                                  Execute := FALSE);
	              
	              // If workaround was set, then reset it
	              IF #statSetOCSWorkaround THEN
	                #statPauseCmdExecution := FALSE;
	                #statSetOCSWorkaround := FALSE;
	              END_IF;
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_SET_USER_FRAME":
	          REGION SET_USER_FRAME
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // User frame
	            #statActiveUserFrames[#tempActiveInstance] := #statUserFrames[#tempActiveInstance];
	            #tempCmdDone := TRUE;
	            //#statActive := TRUE;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	          END_REGION
	          
	        "LKINCTRL_MC_SHIFT_CS_REL":
	          REGION SET_RELATIVE SHIFT
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Relative shift
	            //#statActiveUserFrames[#tempActiveInstance] := #statUserFrames[#tempActiveInstance];
	            #tempCmdDone := TRUE;
	            //#statActive := TRUE;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	          END_REGION
	          
	        "LKINCTRL_MC_RESET_SHIFT":
	          REGION RESET_RELATIVE SHIFT
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Reset relative shift
	            //#statActiveUserFrames[#tempActiveInstance] := #statUserFrames[#tempActiveInstance];
	            #tempCmdDone := TRUE;
	            //#statActive := TRUE;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	          END_REGION
	          
	        "LKINCTRL_MC_ACTIVATE_TOOL":
	          REGION SET_TOOL
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Call instance to update outputs
	            #instMC_SetTool(AxesGroup := #to_Kinematics,
	                            Execute := TRUE);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_SetTool.Done;
	            //#statActive := #instMC_SetTool.Busy;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_SetTool.Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              // Also exclude 16#80C8 -> Is thrown if Stop is triggered during SetTool
	              IF (#instMC_SetTool.ErrorId = 16#80C8 AND #statExecGroupStop)
	                OR #instMC_SetTool.ErrorId = 16#80CD
	              THEN
	                ;//Throw no error
	                //#statStatus := #ERR_SETTOOL_CMD;
	              ELSE
	                #statStatus := #ERR_SETTOOL_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_SetTool.ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            // Check if setTool is done
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_SetTool(AxesGroup := #to_Kinematics,
	                              Execute := FALSE);
	              
	              #statPauseCmdExecution := FALSE;
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_SET_TOOL_FRAME":
	          REGION DEFINE_TOOL
	            // set state to signalize configuration command running
	            // Only do this if status is not a specific other status e.g. "STATUS_CMD_EXECUTED"
	            IF #statStatus = #STATUS_SUBSEQUENT_CALL THEN
	              #statStatus := #STATUS_CONFIGURATION_COMMAND;
	            END_IF;
	            
	            // Call instance to update outputs
	            #instMC_DefineTool(AxesGroup := #to_Kinematics,
	                               Execute := TRUE);
	            
	            // Check outputs
	            #tempCmdDone := #instMC_DefineTool.Done;
	            //#statActive := #instMC_DefineTool.Busy;
	            // Set bit to signal no motion cmd
	            #tempConfigCmd := TRUE;
	            
	            IF #instMC_DefineTool.Error THEN
	              // exclude error from MC_GroupStop ==> handled in stop routine
	              // Also exclude 16#80C8 -> Is thrown if Stop is triggered during DefineTool
	              IF (#instMC_DefineTool.ErrorId = 16#80C8 AND #statExecGroupStop)
	                OR #instMC_DefineTool.ErrorId = 16#80CD
	              THEN
	                ;//Throw no error
	                //#statStatus := #ERR_DEFINETOOL_CMD;
	              ELSE
	                #statStatus := #ERR_DEFINETOOL_CMD;
	              END_IF;
	              #statSubfunctionStatus := #instMC_DefineTool.ErrorId;
	              #diagnostics.#faultFBNumber := #tempActiveInstance;
	              #diagnostics.#faultSetNumber := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].setNumber;
	              #diagnostics.#faultPathDataName := #statStoreExecuteBuffer.bufferElement[#statStoreExecuteBuffer.activeBufferElement].pathDataName;
	            END_IF;
	            
	            // Check if defineTool is done
	            IF #tempCmdDone THEN
	              // Reset instance to reset outputs
	              #instMC_DefineTool(AxesGroup := #to_Kinematics,
	                                 Execute := FALSE);
	              
	              #statPauseCmdExecution := FALSE;
	            END_IF;
	          END_REGION
	          
	        "LKINCTRL_MC_DEFINE_WS_ZONE":
	          REGION DEFINE_WS_ZONE
	            // set state to signalize configuration command running
