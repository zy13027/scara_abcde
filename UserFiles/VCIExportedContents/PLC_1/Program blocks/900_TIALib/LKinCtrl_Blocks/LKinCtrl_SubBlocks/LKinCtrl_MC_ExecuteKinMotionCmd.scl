	      IF #statStateMachine = #EXEC_DEFINE_KIN_ZONE THEN
	        
	        // Reset instance
	        #instMC_DefineKinZone[#statFBCounterDefineKinZone](AxesGroup := #to_Kinematics,
	                                                           Execute := FALSE);
	        
