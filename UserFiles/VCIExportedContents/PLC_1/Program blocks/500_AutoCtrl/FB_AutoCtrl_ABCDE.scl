FUNCTION_BLOCK "FB_AutoCtrl_ABCDE"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.1
// =====================================================================
// SCARA ABCDE 5-Point Continuous Auto Cycle
// (2026-05-17 rev 2.1 — fixed invalid per-element Position[i] := assignment)
//
// CHANGES vs v2.0:
//   - Position parameter to MC_MoveLinearAbsolute: changed from per-element
//     `Position[1] := ..., Position[2] := ...` (which TIA V20 SCL rejects)
//     to whole-array `Position := #tempPosArray` per the proven v9 pattern
//     in FB_TestRawMoveLinAbs.scl line 45
//
// CHANGES vs v1.0 (backed up at .backup/2026-05-17/500_AutoCtrl/):
//   - Step pattern: 11-state → 6-state per source spec §3.3
//   - Removed LKinCtrl-dependent permissive per source spec line 11
//
// Wang Shuo / Huashili 4-REGION pattern (source spec §3.3+§3.5):
//   REGION 1: 初始化路径 / INITIALIZE_PATH
//   REGION 2: 启动 / START                — permissive AND → step:=10
//   REGION 3: 停止 / STOP                 — R_TRIG → step:=0
//   REGION 4: 自动 / AUTO main CASE       — 6 states (0/10/20/30/40/50)
//     0=idle, 10=去A, 20=去B, 30=去C, 40=去D, 50=去E (cycle wrap 50→10)
//
// ONE shared instMoveLinAbs (multi-instance) re-triggered per step on
// rising-edge of step change. KEY to avoiding v9's OB91 overflow.
// =====================================================================

   VAR
      // === Edge-detect instances (Wang Shuo pattern) ===
      sRTRIGInitialPath { S7_SetPoint := 'False' } : R_TRIG;
      sRTRIGStart       { S7_SetPoint := 'False' } : R_TRIG;
      sRTRIGStop        { S7_SetPoint := 'False' } : R_TRIG;

      // === Motion FB: ONE system MC_MoveLinearAbsolute, re-triggered per step ===
      instMoveLinAbs { InstructionName := 'MC_MOVELINEARABSOLUTE'; LibVersion := '9.0'; S7_SetPoint := 'False' } : MC_MOVELINEARABSOLUTE;

      // === 5-point hardcoded ABCDE path (set in REGION 1) ===
      pts { S7_SetPoint := 'False' } : Array[1..5] of "UDT_typePoint5";

      // === Static state ===
      statTargetPos    { ExternalWritable := 'False' } : "UDT_typePoint5";   // currently commanded target (HMI display)
      statOldStep      { S7_SetPoint := 'False' } : Int;                      // for step-change edge detection
      statMoveDoneOld  { S7_SetPoint := 'False' } : Bool;                     // for MoveLinAbs.Done rising-edge detection
      statExecutePulse { S7_SetPoint := 'False' } : Bool;                     // one-scan Execute pulse on step change
   END_VAR

   VAR_TEMP
      tempCurrentPtIdx : Int;                  // 1..5 mapping from i16_AutoStep
      tempStepChanged  : Bool;
      tempIsAutoStep   : Bool;                 // TRUE when step IN [10..50]
      tempPosArray     : Array[1..6] of LReal; // Position array for MC_MoveLinAbs call (4 used + 2 trailing zeros)
   END_VAR


BEGIN

	// =====================================================================
	// REGION 1 — INITIALIZE_PATH (source spec §2.1)
	// =====================================================================
	#sRTRIGInitialPath(CLK := "GDB_MachineCmd".bo_InitPath);
	IF #sRTRIGInitialPath.Q THEN
	    // ABCDE — square pattern in WCS, all at Z=400mm above home.
	    #pts[1].x := 1800.0;  #pts[1].y :=    0.0;  #pts[1].z := 400.0;  #pts[1].a := 0.0;   // A
	    #pts[2].x := 1800.0;  #pts[2].y :=  300.0;  #pts[2].z := 400.0;  #pts[2].a := 0.0;   // B
	    #pts[3].x := 1500.0;  #pts[3].y :=  300.0;  #pts[3].z := 400.0;  #pts[3].a := 0.0;   // C
	    #pts[4].x := 1500.0;  #pts[4].y := -300.0;  #pts[4].z := 400.0;  #pts[4].a := 0.0;   // D
	    #pts[5].x := 1800.0;  #pts[5].y := -300.0;  #pts[5].z := 400.0;  #pts[5].a := 0.0;   // E
	    "GDB_MachineCmd".bo_PathInitialed := TRUE;
	END_IF;

	// =====================================================================
	// REGION 2 — START (source spec §2.2)
	// =====================================================================
	#sRTRIGStart(CLK := "GDB_MachineCmd".bo_Start);
	IF "GDB_MachineCmd".bo_Mode
	   AND "GDB_MachineCmd".bo_ESTOP_LOCK
	   AND ("GDB_MachineCmd".i16_AutoStep = 0)
	   AND #sRTRIGStart.Q
	   AND "GDB_MachineCmd".bo_PathInitialed
	   AND NOT "GDB_MachineCmd".bo_Alarm
	THEN
	    "GDB_MachineCmd".i16_AutoStep := 10;
	END_IF;

	// =====================================================================
	// REGION 3 — STOP (source spec §2.3)
	// =====================================================================
	#sRTRIGStop(CLK := "GDB_MachineCmd".bo_Stop);
	IF #sRTRIGStop.Q THEN
	    "GDB_MachineCmd".i16_AutoStep := 0;
	END_IF;

	// =====================================================================
	// REGION 4 — AUTO main CASE (source spec §3.3, 6 states)
	// =====================================================================

	// Detect step-change for Execute pulse
	#tempStepChanged := ("GDB_MachineCmd".i16_AutoStep <> #statOldStep);
	#statOldStep := "GDB_MachineCmd".i16_AutoStep;

	// Classify current step as "active auto step" [10..50]
	#tempIsAutoStep := ("GDB_MachineCmd".i16_AutoStep >= 10)
	                   AND ("GDB_MachineCmd".i16_AutoStep <= 50);

	// Map step → point index (10→1, 20→2, 30→3, 40→4, 50→5)
	IF #tempIsAutoStep THEN
	    #tempCurrentPtIdx := "GDB_MachineCmd".i16_AutoStep / 10;
	    #statTargetPos := #pts[#tempCurrentPtIdx];
	END_IF;

	// Execute pulse: high for ONE scan when entering a new auto step
	#statExecutePulse := #tempStepChanged AND #tempIsAutoStep;

	// Build the 6-element Position array (4 used + 2 trailing zeros)
	#tempPosArray[1] := #statTargetPos.x;
	#tempPosArray[2] := #statTargetPos.y;
	#tempPosArray[3] := #statTargetPos.z;
	#tempPosArray[4] := #statTargetPos.a;
	#tempPosArray[5] := 0.0;
	#tempPosArray[6] := 0.0;

	// Drive MC_MoveLinearAbsolute on the kinematic group.
	// Raw system FB — no LKinCtrl wrapper (source spec line 11).
	// Whole-array Position passing per v9 FB_TestRawMoveLinAbs.scl line 45.
	#instMoveLinAbs(AxesGroup    := "ScaraArm3D",
	                Execute      := #statExecutePulse,
	                Position     := #tempPosArray,
	                Velocity     := 300.0,
	                Acceleration := 3000.0,
	                Deceleration := 3000.0,
	                Jerk         := 30000.0,
	                BufferMode   := 1);   // 1 = BM_BUFFERED (basic, source spec §3.4)
	                                      //     For V8 blending (Phase F): change to 5 = BM_BLENDING_HIGH

	// On MoveLinAbs.Done rising-edge in an auto step, advance to next step
	// (source spec §3.4 + §3.5 cycle wrap at step=50)
	IF #instMoveLinAbs.Done AND NOT #statMoveDoneOld AND #tempIsAutoStep THEN
	    IF "GDB_MachineCmd".i16_AutoStep = 50 THEN
	        "GDB_MachineCmd".i16_AutoStep := 10;        // cycle wrap E → A (§3.5)
	    ELSE
	        "GDB_MachineCmd".i16_AutoStep :=
	            "GDB_MachineCmd".i16_AutoStep + 10;     // 10→20→30→40→50
	    END_IF;
	END_IF;
	#statMoveDoneOld := #instMoveLinAbs.Done;

END_FUNCTION_BLOCK
