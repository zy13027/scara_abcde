FUNCTION_BLOCK "FB_ManualCtrl"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.2
// =====================================================================
// SCARA ABCDE - Manual Control Surface  (Phase 5, 2026-05-21)
//
// Runs in OB1 (process logic). Routes HMI manual-mode commands
// (GDB_ManualCmd) to the 600 axis layer by WRITING GDB_AxisCtrl - it
// never calls an MC instruction.
//   REGION Mode_Gate              - compute statManualOK (mutex + safety)
//   REGION Group_Enable_Home_Reset- Enable/Home/Reset -> GDB_AxisCtrl input
//   REGION Cartesian_Jog          - HMI jog buttons -> ...input.jogframe;
//                                   FB_AxisCtrl (OB30) runs LKinCtrl_MC_JogFrame.
//   REGION Kin_Manual_Move        - bo_KinGo -> ...input.movelinear (the same
//                                   interface the auto FBs use).
//   REGION Status_Mirror          - TO StatusWord + GDB_AxisCtrl -> GDB_ManualStatus
//
// V1.2 (2026-05-22) - Task #5: REGION Group_Enable_Home_Reset stands down while
// FB_AxisCtrl's guided recovery runs (GDB_AxisCtrl.LKinCtrl.output.bo_recovering),
// so the recovery sequencer is the single writer of input.bo_enable/home/reset.
// V1.1 (2026-05-22) - REGION Kin_Manual_Move sets input.movelinear.bo_isPTP
// := FALSE so manual moves stay Cartesian linear (FB_AxisCtrl V2.3 added a
// PTP route on that shared bit for the palletizing transits).
// V1.0 (Phase 5) - rebuilt: the 4x MC_MoveJog and the 1x MC_MoveLinear-
// Absolute are removed. MC_MoveJog conflicts with axes inside a kinematics
// group, so jog now goes through LKinCtrl_MC_JogFrame in the OB30 layer.
//
// Jog is CARTESIAN (WCS): the HMI's 4 jog axis-pairs drive the TCP in
// X / Y / Z / A. The bo_J{n}_Jog* button names are legacy - the Phase 6
// HMI update relabels them X/Y/Z/A.
//
// Mutex: statManualOK := bo_Mode AND bo_ESTOP_LOCK AND NOT
// GDB_MachineCmd.bo_Mode. When FALSE, REGIONs 2-4 make no motion writes
// (jog bits forced FALSE); REGION Status_Mirror always runs.
// =====================================================================
   VAR
      sRTRIGKinGo {InstructionName := 'R_TRIG'; LibVersion := '1.0'} : R_TRIG;
      statManualOK : Bool;
   END_VAR

   VAR_TEMP
      tempEnableAxes : Bool;
      tempHomeAxes : Bool;
      tempResetAxes : Bool;
   END_VAR


BEGIN

    REGION Mode_Gate
        // statManualOK gates the routing regions. Mutex with the auto FBs:
        // manual requires ABCDE auto mode (GDB_MachineCmd.bo_Mode) is FALSE.
        #statManualOK := "GDB_ManualCmd".bo_Mode
                         AND "GDB_ManualCmd".bo_ESTOP_LOCK
                         AND NOT "GDB_MachineCmd".bo_Mode;
    END_REGION

    REGION Group_Enable_Home_Reset
        // Per-axis + Kin-group Enable/Home/Reset buttons OR into the shared
        // GDB_AxisCtrl group request bits. FB_AxisCtrl (OB30) drives the
        // LKinCtrl group power / reset; FB_Init drives the homing. Per-axis
        // is a UX nicety - enable/home/reset are group-level. Task #5: while
        // FB_AxisCtrl's guided recovery runs (output.bo_recovering), it owns
        // these bits - this region stands down so there is a single writer.
        IF #statManualOK AND NOT "GDB_AxisCtrl".LKinCtrl.output.bo_recovering THEN
            #tempEnableAxes := "GDB_ManualCmd".bo_J1_Enable
                               OR "GDB_ManualCmd".bo_J2_Enable
                               OR "GDB_ManualCmd".bo_J3_Enable
                               OR "GDB_ManualCmd".bo_J4_Enable
                               OR "GDB_ManualCmd".bo_KinEnable;
            #tempHomeAxes := "GDB_ManualCmd".bo_J1_Home
                             OR "GDB_ManualCmd".bo_J2_Home
                             OR "GDB_ManualCmd".bo_J3_Home
                             OR "GDB_ManualCmd".bo_J4_Home
                             OR "GDB_ManualCmd".bo_KinHome;
            #tempResetAxes := "GDB_ManualCmd".bo_J1_Reset
                              OR "GDB_ManualCmd".bo_J2_Reset
                              OR "GDB_ManualCmd".bo_J3_Reset
                              OR "GDB_ManualCmd".bo_J4_Reset
                              OR "GDB_ManualCmd".bo_KinReset;

            "GDB_AxisCtrl".LKinCtrl.input.bo_enable := #tempEnableAxes;
            "GDB_AxisCtrl".LKinCtrl.input.bo_home   := #tempHomeAxes;
            "GDB_AxisCtrl".LKinCtrl.input.bo_reset  := #tempResetAxes;
        END_IF;
    END_REGION

    REGION Cartesian_Jog
        // HMI jog buttons -> GDB_AxisCtrl.LKinCtrl.input.jogframe Cartesian
        // direction bits. WCS frame jog: the 4 HMI axis-pairs drive
        // X (J1 buttons) / Y (J2) / Z (J3) / A (J4). XOR safety - if both
        // forward + backward are held, neither wins. Each bit is ANDed with
        // statManualOK, so leaving manual mode forces every jog bit FALSE.
        // SCARA is 4-DOF: the B / C jog directions are held FALSE.
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogX+" := #statManualOK AND "GDB_ManualCmd".bo_J1_JogForward  AND NOT "GDB_ManualCmd".bo_J1_JogBackward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogX-" := #statManualOK AND "GDB_ManualCmd".bo_J1_JogBackward AND NOT "GDB_ManualCmd".bo_J1_JogForward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogY+" := #statManualOK AND "GDB_ManualCmd".bo_J2_JogForward  AND NOT "GDB_ManualCmd".bo_J2_JogBackward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogY-" := #statManualOK AND "GDB_ManualCmd".bo_J2_JogBackward AND NOT "GDB_ManualCmd".bo_J2_JogForward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogZ+" := #statManualOK AND "GDB_ManualCmd".bo_J3_JogForward  AND NOT "GDB_ManualCmd".bo_J3_JogBackward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogZ-" := #statManualOK AND "GDB_ManualCmd".bo_J3_JogBackward AND NOT "GDB_ManualCmd".bo_J3_JogForward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogA+" := #statManualOK AND "GDB_ManualCmd".bo_J4_JogForward  AND NOT "GDB_ManualCmd".bo_J4_JogBackward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogA-" := #statManualOK AND "GDB_ManualCmd".bo_J4_JogBackward AND NOT "GDB_ManualCmd".bo_J4_JogForward;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogB+" := FALSE;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogB-" := FALSE;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogC+" := FALSE;
        "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogC-" := FALSE;
    END_REGION

    REGION Kin_Manual_Move
        // bo_KinGo rising edge -> a point-to-point move to the operator-set
        // (cfgKinTargetX/Y/Z/A) via the shared movelinear interface (the
        // OB30 axis layer runs the MC). The R_TRIG runs every scan; the move
        // is issued only in manual mode. bo_execute is held until FB_AxisCtrl
        // reports the move done. Manual dynamics: 200 mm/s (auto cycle: 300).
        #sRTRIGKinGo(CLK := "GDB_ManualCmd".bo_KinGo);
        IF #statManualOK THEN
            IF #sRTRIGKinGo.Q THEN
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.x := "GDB_ManualCmd".cfgKinTargetX;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.y := "GDB_ManualCmd".cfgKinTargetY;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.z := "GDB_ManualCmd".cfgKinTargetZ;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.a := "GDB_ManualCmd".cfgKinTargetA;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.b := 0.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.c := 0.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_velocity     := 200.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_acceleration := 2000.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_deceleration := 2000.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_jerk         := 20000.0;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.bo_isPTP         := FALSE;
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.bo_execute       := TRUE;
            END_IF;
            // drop the execute hold once the OB30 axis layer reports done
            IF "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_done THEN
                "GDB_AxisCtrl".LKinCtrl.input.movelinear.bo_execute := FALSE;
            END_IF;
        END_IF;
    END_REGION

    REGION Status_Mirror
        // TO StatusWord bits + GDB_AxisCtrl outputs -> GDB_ManualStatus.
        // Runs every scan (NOT gated on statManualOK) so HMI lamps show the
        // truth regardless of mode. StatusWord (Siemens TO_PositioningAxis
        // MC 9.0): %X1 = Error, %X5 = Homed, %X7 = Standstill (NOT-%X7 =
        // motion in progress). Group power is all-or-nothing
        // (LKinCtrl_MC_GroupPower) - all 4 joints mirror the group bo_enabled.
        "GDB_ManualStatus".bo_J1_Enabled := "GDB_AxisCtrl".LKinCtrl.output.bo_enabled;
        "GDB_ManualStatus".bo_J2_Enabled := "GDB_AxisCtrl".LKinCtrl.output.bo_enabled;
        "GDB_ManualStatus".bo_J3_Enabled := "GDB_AxisCtrl".LKinCtrl.output.bo_enabled;
        "GDB_ManualStatus".bo_J4_Enabled := "GDB_AxisCtrl".LKinCtrl.output.bo_enabled;

        "GDB_ManualStatus".bo_J1_Homed := "J1_SCARA_Arm3D".StatusWord.%X5;
        "GDB_ManualStatus".bo_J2_Homed := "J2_SCARA_Arm3D".StatusWord.%X5;
        "GDB_ManualStatus".bo_J3_Homed := "J3_SCARA_Arm3D".StatusWord.%X5;
        "GDB_ManualStatus".bo_J4_Homed := "J4_SCARA_Arm3D".StatusWord.%X5;

        "GDB_ManualStatus".bo_J1_Error := "J1_SCARA_Arm3D".StatusWord.%X1;
        "GDB_ManualStatus".bo_J2_Error := "J2_SCARA_Arm3D".StatusWord.%X1;
        "GDB_ManualStatus".bo_J3_Error := "J3_SCARA_Arm3D".StatusWord.%X1;
        "GDB_ManualStatus".bo_J4_Error := "J4_SCARA_Arm3D".StatusWord.%X1;

        "GDB_ManualStatus".bo_J1_JogActive := NOT "J1_SCARA_Arm3D".StatusWord.%X7;
        "GDB_ManualStatus".bo_J2_JogActive := NOT "J2_SCARA_Arm3D".StatusWord.%X7;
        "GDB_ManualStatus".bo_J3_JogActive := NOT "J3_SCARA_Arm3D".StatusWord.%X7;
        "GDB_ManualStatus".bo_J4_JogActive := NOT "J4_SCARA_Arm3D".StatusWord.%X7;

        "GDB_ManualStatus".bo_KinEnabled := "GDB_AxisCtrl".LKinCtrl.output.bo_enabled;
        "GDB_ManualStatus".bo_KinHomed   := "GDB_AxisCtrl".LKinCtrl.output.bo_homed;
        "GDB_ManualStatus".bo_KinError   := "GDB_AxisCtrl".LKinCtrl.output.bo_fault;
        "GDB_ManualStatus".bo_KinReady   := "GDB_AxisCtrl".LKinCtrl.output.bo_ready;
        "GDB_ManualStatus".bo_KinManualBusy := "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_busy;
    END_REGION

END_FUNCTION_BLOCK
