FUNCTION_BLOCK "FB_MCDDataTransfer"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.2
// =====================================================================
// FB_MCDDataTransfer rev 0.2 (2026-05-17 Phase C.0)
//
// CHANGES vs rev 0.1:
//   - ADDED 8 explicit-named direct-from-TO_Axis assignments after the
//     existing kinematic-group FOR loop:
//       GDB_MCDData.J{1..4}_{ActualPosition, ActualVelocity} :=
//         J{1..4}_SCARA_Arm3D.{ActualPosition, ActualVelocity};
//
// RATIONALE: TO_Axis tags (J{n}_SCARA_Arm3D.ActualPosition + ActualVelocity)
// are NOT exposed via PLCSIM-Adv API directly (returns Error -4 DoesNotExist).
// HMI runtime reads them fine via TIA's S7 driver (HMI agent's TIA Compile
// passed 0E/0W against those bindings per CompileGreen handoff). For
// PLCSIM-Adv API monitoring + future tooling parity, mirror them to
// explicit-named GDB members.
//
// The existing kinematic-group FOR loop (Position[1..4] + Velocity[1..4])
// stays for back-compat with NX MCD signal adapter consumers + existing
// smoke-test code.
//
// HMI binding strategy is UNCHANGED — HMI continues to read TO_Axis direct
// via S7 driver (per HMI agent's UBP design). The new GDB members are
// PLC-side diagnostic mirror only, NOT a new HMI surface.
// =====================================================================
   VAR_TEMP
      tempIndex : Int;
   END_VAR


BEGIN
	// Kinematic-group view of per-axis data (rev 0.1, preserved for back-compat):
	FOR #tempIndex := 1 TO 4 DO

	    "GDB_MCDData".Position[#tempIndex] := "ScaraArm3D".AxesData.A[#tempIndex].Position;

	    "GDB_MCDData".Velocity[#tempIndex] := "ScaraArm3D".AxesData.A[#tempIndex].Velocity;
	END_FOR;

	// === Phase C.0 (rev 0.2) — explicit-named direct-from-TO_Axis mirror ===
	// Closes PLCSIM-Adv API gap for TO_Axis tag access. HMI runtime still
	// reads TO_Axis direct via S7 driver; these mirror fields exist for
	// PLCSIM-Adv API / future tooling parity. See FB header comment.
	"GDB_MCDData".J1_ActualPosition := "J1_SCARA_Arm3D".ActualPosition;
	"GDB_MCDData".J1_ActualVelocity := "J1_SCARA_Arm3D".ActualVelocity;
	"GDB_MCDData".J2_ActualPosition := "J2_SCARA_Arm3D".ActualPosition;
	"GDB_MCDData".J2_ActualVelocity := "J2_SCARA_Arm3D".ActualVelocity;
	"GDB_MCDData".J3_ActualPosition := "J3_SCARA_Arm3D".ActualPosition;
	"GDB_MCDData".J3_ActualVelocity := "J3_SCARA_Arm3D".ActualVelocity;
	"GDB_MCDData".J4_ActualPosition := "J4_SCARA_Arm3D".ActualPosition;
	"GDB_MCDData".J4_ActualVelocity := "J4_SCARA_Arm3D".ActualVelocity;

END_FUNCTION_BLOCK

