FUNCTION_BLOCK "FB_AxisCtrl"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.2
// =====================================================================
// SCARA ABCDE - Axis / Kinematics Control  (Phase 5, 2026-05-21)
//
// The single Motion Control owner. Belongs to the 600 axis/kinematics
// layer; runs in OB30 (CyclicInterrupt_10ms, 10 ms), decoupled from the
// 500 process logic in OB1. All I/O is the consolidated
// GDB_AxisCtrl.LKinCtrl interface (the OB1<->OB30 shared-DB bridge).
//
// V2.2 - adds the Cartesian frame jog owner (REGION JogFrame). FB_ManualCtrl
// no longer calls MC_MoveJog (which conflicts with axes inside a kinematics
// group): it sets direction bits in GDB_AxisCtrl.LKinCtrl.input.jogframe and
// this FB runs LKinCtrl_MC_JogFrame on ScaraArm3D in the WCS frame.
//
// V2.1 - kinematic linear-move owner (REGION MoveLinear): the auto FBs
// write GDB_AxisCtrl.LKinCtrl.input.movelinear + hold bo_execute; this FB
// runs the one MC_MoveLinearAbsolute.
//
// V2.0 - rebuilt on the approved LKinCtrl library (郑老板 approval):
//   Power 4x MC_Power -> LKinCtrl_MC_GroupPower; Reset 5x MC_Reset ->
//   LKinCtrl_MC_GroupReset; Home moved OUT to FB_Init; SetTool one-shot kept.
// =====================================================================
   VAR
      instGroupPower : "LKinCtrl_MC_GroupPower";
      instGroupReset : "LKinCtrl_MC_GroupReset";
      instMC_SetTool {InstructionName := 'MC_SETTOOL'; LibVersion := '9.0'} : MC_SETTOOL;
      instMoveLinAbs {InstructionName := 'MC_MOVELINEARABSOLUTE'; LibVersion := '9.0'; S7_SetPoint := 'False'} : MC_MOVELINEARABSOLUTE;
      instJogFrame : "LKinCtrl_MC_JogFrame";
      statToolActivated : Bool;   // one-shot SetTool latch; cleared by memory reset
   END_VAR

   VAR_TEMP
      tempPos : Array[1..6] of LReal;   // Cartesian Position array for MC_MoveLinearAbsolute
      tempJogFwd : Bool;   // resolved jog-forward for LKinCtrl_MC_JogFrame
      tempJogBwd : Bool;   // resolved jog-backward for LKinCtrl_MC_JogFrame
      tempJogDir : USInt;   // resolved jog direction (1=X 2=Y 3=Z 4=A 5=B 6=C)
   END_VAR


BEGIN

    REGION Power
        // Enable all kinematic axes via the library group-power FB.
        // startMode / stopMode arrays come from the consolidated config.
        #instGroupPower(enable    := "GDB_AxisCtrl".LKinCtrl.input.bo_enable,
                        startMode := "GDB_AxisCtrl".LKinCtrl.input.configuration.power.startMode,
                        stopMode  := "GDB_AxisCtrl".LKinCtrl.input.configuration.power.stopMode,
                        axesGroup := "ScaraArm3D");
        "GDB_AxisCtrl".LKinCtrl.output.bo_enabled := #instGroupPower.axesEnabled;
    END_REGION

    REGION Reset
        // Reset all axes + the kinematics TO via the library group-reset FB.
        #instGroupReset(execute   := "GDB_AxisCtrl".LKinCtrl.input.bo_reset,
                        restart   := "GDB_AxisCtrl".LKinCtrl.input.configuration.reset.restart,
                        axesGroup := "ScaraArm3D");
    END_REGION

    REGION Fault
        "GDB_AxisCtrl".LKinCtrl.output.bo_fault := #instGroupPower.error
                                                   OR #instGroupReset.error;
    END_REGION

    REGION SetTool
        // One-shot Tool[1] activation once the group is enabled. Without an
        // active tool, MC_MoveLinearAbsolute returns UserFault (documented
        // root cause). Idempotent: latches statToolActivated, drops Execute
        // after Done. Cleared by memory reset.
        IF "GDB_AxisCtrl".LKinCtrl.output.bo_enabled AND NOT #statToolActivated THEN
            #instMC_SetTool(AxesGroup  := "ScaraArm3D",
                            Execute    := TRUE,
                            ToolNumber := 1);
            IF #instMC_SetTool.Done THEN
                #instMC_SetTool(AxesGroup := "ScaraArm3D",
                                Execute   := FALSE);
                #statToolActivated := TRUE;
            END_IF;
        END_IF;
    END_REGION

    REGION MoveLinear
        // Kinematic linear move on ScaraArm3D. The auto FBs (OB1) write the
        // target pose + dynamics into GDB_AxisCtrl.LKinCtrl.input.movelinear
        // and hold bo_execute; this region runs the one MC_MoveLinearAbsolute
        // and mirrors its status into output.movelinear for the auto FB's
        // wait-in-place step. BufferMode 1 (buffered) - the auto CASE
        // serializes moves (one per step, waits for Done), so no
        // cross-command blending is needed.
        #tempPos[1] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.x;
        #tempPos[2] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.y;
        #tempPos[3] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.z;
        #tempPos[4] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.a;
        #tempPos[5] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.b;
        #tempPos[6] := "GDB_AxisCtrl".LKinCtrl.input.movelinear.targetposition.c;

        #instMoveLinAbs(AxesGroup    := "ScaraArm3D",
                        Execute      := "GDB_AxisCtrl".LKinCtrl.input.movelinear.bo_execute,
                        Position     := #tempPos,
                        Velocity     := "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_velocity,
                        Acceleration := "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_acceleration,
                        Deceleration := "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_deceleration,
                        Jerk         := "GDB_AxisCtrl".LKinCtrl.input.movelinear.r64_jerk,
                        BufferMode   := 1);

        "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_done           := #instMoveLinAbs.Done;
        "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_busy           := #instMoveLinAbs.Busy;
        "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_active         := #instMoveLinAbs.Active;
        "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_error          := #instMoveLinAbs.Error;
        "GDB_AxisCtrl".LKinCtrl.output.movelinear.bo_commandaborted := #instMoveLinAbs.CommandAborted;
    END_REGION

    REGION JogFrame
        // Cartesian frame jog of ScaraArm3D in the WCS. FB_ManualCtrl (OB1)
        // sets the direction bits in GDB_AxisCtrl.LKinCtrl.input.jogframe;
        // this region resolves the one active bit to a (jogDirection,
        // jogForward/Backward) pair and runs LKinCtrl_MC_JogFrame. The ELSIF
        // chain picks a single direction - LKinCtrl errors on two at once.
        #tempJogFwd := FALSE;
        #tempJogBwd := FALSE;
        #tempJogDir := 1;
        IF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogX+" THEN
            #tempJogDir := 1; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogX-" THEN
            #tempJogDir := 1; #tempJogBwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogY+" THEN
            #tempJogDir := 2; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogY-" THEN
            #tempJogDir := 2; #tempJogBwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogZ+" THEN
            #tempJogDir := 3; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogZ-" THEN
            #tempJogDir := 3; #tempJogBwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogA+" THEN
            #tempJogDir := 4; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogA-" THEN
            #tempJogDir := 4; #tempJogBwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogB+" THEN
            #tempJogDir := 5; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogB-" THEN
            #tempJogDir := 5; #tempJogBwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogC+" THEN
            #tempJogDir := 6; #tempJogFwd := TRUE;
        ELSIF "GDB_AxisCtrl".LKinCtrl.input.jogframe."jogC-" THEN
            #tempJogDir := 6; #tempJogBwd := TRUE;
        END_IF;

        #instJogFrame(jogForward   := #tempJogFwd,
                      jogBackward  := #tempJogBwd,
                      jogDirection := #tempJogDir,
                      jogModeInc   := FALSE,
                      coordSystem  := 0,
                      tool         := 1,
                      dynamics     := "GDB_AxisCtrl".LKinCtrl.input.configuration.jogframe.dynamics,
                      axesGroup    := "ScaraArm3D");
    END_REGION

    REGION StatusDerived
        // bo_ready = enabled AND homed AND NOT fault. bo_homed is written
        // by FB_Init - call FB_Init before FB_AxisCtrl in OB30.
        "GDB_AxisCtrl".LKinCtrl.output.bo_ready :=
            "GDB_AxisCtrl".LKinCtrl.output.bo_enabled
            AND "GDB_AxisCtrl".LKinCtrl.output.bo_homed
            AND NOT "GDB_AxisCtrl".LKinCtrl.output.bo_fault;
    END_REGION

END_FUNCTION_BLOCK
