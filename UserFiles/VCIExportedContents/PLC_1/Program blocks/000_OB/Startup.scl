ORGANIZATION_BLOCK "Startup"
TITLE = "Complete Restart"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
// =====================================================================
// SCARA ABCDE â€” Startup (OB100)
//
// 2026-05-17 â€” Minimal startup for ABCDE 5-point demo.
// Initializes GDB_Control arrays so retain-memory drift can never zero
// them (defense pattern proven in v9, see Memory MEMORY.md â†’ cfg-retain
// fix). Clears command bits so warm-start can't replay an in-flight cmd.
//
// All HMI cmd bits live in GDB_MachineCmd (initialized via Member
// StartValue attributes in the XML â€” bo_Mode and bo_ESTOP_LOCK both
// default TRUE so an operator can immediately start). i16_AutoStep
// defaults to 0 (idle) which is the safe state.
// =====================================================================
   VAR_TEMP 
      i : Int;
   END_VAR


BEGIN
	
	 REGION Set_GroupPower_StartStopMode_defaults
	     // LKinCtrl_MC_GroupPower reads GDB_Control.StartMode[i] / StopMode[i].
	     // If any element is 0 on cold start / warm-start retain drift, MC_Power
	     // silently refuses to assert axesEnabled  - busy stuck FALSE forever.
	     // Set all 6 elements of both arrays to 1 (position-controlled enable /
	     // standard immediate-stop) on every PLC startup.
	     FOR #i := 1 TO 6 DO
	         "GDB_Control".StartMode[#i] := 1;   // 1 = enable position-controlled
	         "GDB_Control".StopMode[#i]  := 1;   // 1 = immediate stop
	     END_FOR;
	 END_REGION
	
	 REGION Set_GroupHome_defaults
	     // LKinCtrl_MC_GroupHome reads GDB_Control.HomePos[i] / HomeMode[i].
	     // HomeMode=7 ("set actual position") is used in the SCARA demo so
	     // no physical homing motion is needed  - the operator clicks Home
	     // and the current TO joint position becomes the home reference.
	     //
	     // HomePos values per kinematic-axis index (A1=J1 base, A2=J3 z,
	     // A3=J2 elbow, A4=J4 wrist) match the SCARA3D zero pose. Indexes
	     // 5/6 (B/C orientation) unused in this 4-DOF kinematic.
	     "GDB_Control".HomePos[1] := 0.0;   // A1 = J1 base shoulder
	     "GDB_Control".HomePos[2] := 0.0;   // A2 = J3 prismatic z
	     "GDB_Control".HomePos[3] := 0.0;   // A3 = J2 elbow
	     "GDB_Control".HomePos[4] := 0.0;   // A4 = J4 wrist
	     "GDB_Control".HomePos[5] := 0.0;   // unused
	     "GDB_Control".HomePos[6] := 0.0;   // unused
	     FOR #i := 1 TO 6 DO
	         "GDB_Control".HomeMode[#i] := 7;   // 7 = set actual position (no motion)
	     END_FOR;
	 END_REGION
	
	 REGION Set_GroupReset_RestartMode_defaults
	     // LKinCtrl_MC_GroupReset reads GDB_Control.RestartMode[1..7] of Bool.
	     // All FALSE = standard reset (clear axis error, do not re-initialize TO).
	     FOR #i := 1 TO 7 DO
	         "GDB_Control".RestartMode[#i] := FALSE;
	     END_FOR;
	 END_REGION
	
	 REGION Clear_group_motion_command_bits
	     // Defensive: clear group enable/home/reset bits so warm-start can't
	     // replay an in-flight command. Operator must re-click Enable on HMI.
	     "GDB_Control".enableAxes := FALSE;
	     "GDB_Control".resetAxes  := FALSE;
	     "GDB_Control".homeAxes   := FALSE;
	 END_REGION
	
	 REGION Clear_AutoCtrl_command_bits
	     // Wang Shuo pattern: i16_AutoStep is the master state. 0 = idle.
	     // On warm-start, retain may have left step=80 (mid-cycle). Force
	     // back to 0 so operator must explicitly re-Start.
	     "GDB_MachineCmd".i16_AutoStep := 0;
	     "GDB_MachineCmd".bo_PathInitialed := FALSE;  // operator must re-init
	     "GDB_MachineCmd".bo_Alarm := FALSE;
	 END_REGION
	
	 REGION Clear_PalletizingCtrl_command_bits
	     // C69 Phase 2.2 (2026-05-18): defensively clear all palletizing-mode
	     // command bits + i16_PalletStep so warm-start can't replay a partial
	     // cycle. bo_Mode + bo_ESTOP_LOCK keep their XML StartValues (FALSE + TRUE).
	     // bo_PalletInitialed cleared - operator must re-pulse bo_InitPallet on
	     // session start to repopulate pts[] (path table is in iDB statics, not
	     // retain, so it would be all-zeros after memory reset anyway).
	     "GDB_PalletizingCmd".bo_InitPallet := FALSE;
	     "GDB_PalletizingCmd".bo_Start := FALSE;
	     "GDB_PalletizingCmd".bo_Stop := FALSE;
	     "GDB_PalletizingCmd".bo_PalletInitialed := FALSE;
	     "GDB_PalletizingCmd".bo_Alarm := FALSE;
	     "GDB_PalletizingCmd".i16_PalletStep := 0;
	 END_REGION
	
	 REGION Clear_ManualCtrl_command_bits
	     // Phase G (C67, 2026-05-18): defensively clear all manual-mode
	     // command bits so warm-start can't replay a held jog button or
	     // a latched Enable/Home/Reset. Operator must re-press on HMI.
	     // bo_Mode + bo_ESTOP_LOCK keep their XML StartValues (FALSE + TRUE).
	     "GDB_ManualCmd".bo_J1_Enable := FALSE;
	     "GDB_ManualCmd".bo_J2_Enable := FALSE;
	     "GDB_ManualCmd".bo_J3_Enable := FALSE;
	     "GDB_ManualCmd".bo_J4_Enable := FALSE;
	     "GDB_ManualCmd".bo_J1_Home := FALSE;
	     "GDB_ManualCmd".bo_J2_Home := FALSE;
	     "GDB_ManualCmd".bo_J3_Home := FALSE;
	     "GDB_ManualCmd".bo_J4_Home := FALSE;
	     "GDB_ManualCmd".bo_J1_Reset := FALSE;
	     "GDB_ManualCmd".bo_J2_Reset := FALSE;
	     "GDB_ManualCmd".bo_J3_Reset := FALSE;
	     "GDB_ManualCmd".bo_J4_Reset := FALSE;
	     "GDB_ManualCmd".bo_J1_JogForward := FALSE;
	     "GDB_ManualCmd".bo_J1_JogBackward := FALSE;
	     "GDB_ManualCmd".bo_J2_JogForward := FALSE;
	     "GDB_ManualCmd".bo_J2_JogBackward := FALSE;
	     "GDB_ManualCmd".bo_J3_JogForward := FALSE;
	     "GDB_ManualCmd".bo_J3_JogBackward := FALSE;
	     "GDB_ManualCmd".bo_J4_JogForward := FALSE;
	     "GDB_ManualCmd".bo_J4_JogBackward := FALSE;
	     "GDB_ManualCmd".bo_KinEnable := FALSE;
	     "GDB_ManualCmd".bo_KinHome := FALSE;
	     "GDB_ManualCmd".bo_KinReset := FALSE;
	     "GDB_ManualCmd".bo_KinGo := FALSE;
	     // cfgKinTarget{X,Y,Z,A} keep their XML StartValues (A-point safe defaults).
	 END_REGION
	
	
END_ORGANIZATION_BLOCK

