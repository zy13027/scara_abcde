FUNCTION_BLOCK "FB_AxisCtrl"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.1
// =====================================================================
// Per-axis enable / home / reset for SCARA 4-joint kinematic
// (2026-05-17 rev 1.1 — fixed invalid MC_GROUPRESET reference)
//
// CHANGES vs v1.0:
//   - REPLACED `MC_GROUPRESET` (NOT a valid TIA V20 system instruction —
//     verified by reading LKinCtrl_MC_GroupReset.scl in .backup/2026-05-17/:
//     it uses MC_RESET per-axis + MC_RESET on the TO_Kinematics)
//   - Now uses 4× per-axis MC_RESET + 1× MC_RESET on ScaraArm3D kinematic TO
//
// PURPOSE: Replaces LKinCtrl_MC_GroupPower / GroupHome / GroupReset wrappers
// (in .backup/2026-05-17/) with raw system MC instructions per source spec
// line 11 ("不用任何的库" / no libraries).
//
// PER-SCAN MC INSTRUCTION COUNT:
//   - 4× MC_Power (one per joint J1..J4)
//   - 4× MC_Home  (one per joint J1..J4)
//   - 5× MC_Reset (4 per joint + 1 on kinematic TO — LKinCtrl pattern)
//   Total: 13 declared, ~4-5 actively pulsing at any time. Plus
//   FB_AutoCtrl_ABCDE's 1× MC_MoveLinearAbsolute = ~5-6 active MC slots
//   vs v9's ~50 actively pulsing → OB91 headroom preserved.
//
// HMI bindings (via GDB_Control):
//   enableAxes (W Bool)   → MC_Power.Enable for all 4 joints
//   resetAxes  (W Bool)   → MC_Reset.Execute for all 4 joints + kin TO
//   homeAxes   (W Bool)   → MC_Home.Execute for all 4 joints (single rising-edge)
//
// Mirror outputs to GDB_Control:
//   axesEnabled := AND of all 4 MC_Power.Status
//   axesHomed   := AND of all 4 MC_Home.Done
//   axesError   := OR of all errors (Power + Home + Reset)
// =====================================================================

   VAR
      // === Multi-instance MC_Power per joint axis ===
      instPower_J1 { InstructionName := 'MC_POWER'; LibVersion := '9.0' } : MC_POWER;
      instPower_J2 { InstructionName := 'MC_POWER'; LibVersion := '9.0' } : MC_POWER;
      instPower_J3 { InstructionName := 'MC_POWER'; LibVersion := '9.0' } : MC_POWER;
      instPower_J4 { InstructionName := 'MC_POWER'; LibVersion := '9.0' } : MC_POWER;

      // === Multi-instance MC_Home per joint axis ===
      instHome_J1 { InstructionName := 'MC_HOME'; LibVersion := '9.0' } : MC_HOME;
      instHome_J2 { InstructionName := 'MC_HOME'; LibVersion := '9.0' } : MC_HOME;
      instHome_J3 { InstructionName := 'MC_HOME'; LibVersion := '9.0' } : MC_HOME;
      instHome_J4 { InstructionName := 'MC_HOME'; LibVersion := '9.0' } : MC_HOME;

      // === Multi-instance MC_Reset per joint axis + kinematic TO ===
      // (per LKinCtrl_MC_GroupReset pattern at .backup line 38-39)
      instReset_J1  { InstructionName := 'MC_RESET'; LibVersion := '9.0' } : MC_RESET;
      instReset_J2  { InstructionName := 'MC_RESET'; LibVersion := '9.0' } : MC_RESET;
      instReset_J3  { InstructionName := 'MC_RESET'; LibVersion := '9.0' } : MC_RESET;
      instReset_J4  { InstructionName := 'MC_RESET'; LibVersion := '9.0' } : MC_RESET;
      instReset_Kin { InstructionName := 'MC_RESET'; LibVersion := '9.0' } : MC_RESET;
   END_VAR


BEGIN

	// =====================================================================
	// REGION Power — per-axis MC_Power calls
	// All 4 joints share the same enableAxes bit + StartMode[i]/StopMode[i].
	// =====================================================================
	#instPower_J1(Axis      := "J1_SCARA_Arm3D",
	              Enable    := "GDB_Control".enableAxes,
	              StartMode := "GDB_Control".StartMode[1],
	              StopMode  := "GDB_Control".StopMode[1]);

	#instPower_J2(Axis      := "J2_SCARA_Arm3D",
	              Enable    := "GDB_Control".enableAxes,
	              StartMode := "GDB_Control".StartMode[2],
	              StopMode  := "GDB_Control".StopMode[2]);

	#instPower_J3(Axis      := "J3_SCARA_Arm3D",
	              Enable    := "GDB_Control".enableAxes,
	              StartMode := "GDB_Control".StartMode[3],
	              StopMode  := "GDB_Control".StopMode[3]);

	#instPower_J4(Axis      := "J4_SCARA_Arm3D",
	              Enable    := "GDB_Control".enableAxes,
	              StartMode := "GDB_Control".StartMode[4],
	              StopMode  := "GDB_Control".StopMode[4]);

	// Mirror axesEnabled = AND of all 4 Status outputs
	"GDB_Control".axesEnabled := #instPower_J1.Status
	                              AND #instPower_J2.Status
	                              AND #instPower_J3.Status
	                              AND #instPower_J4.Status;

	// =====================================================================
	// REGION Reset — 4 per-axis MC_RESET + 1 on kinematic TO
	// MC_RESET accepts TO_PositioningAxis (joints) AND TO_Kinematics (group).
	// Single rising-edge from HMI resetAxes button.
	// =====================================================================
	#instReset_J1(Axis := "J1_SCARA_Arm3D", Execute := "GDB_Control".resetAxes);
	#instReset_J2(Axis := "J2_SCARA_Arm3D", Execute := "GDB_Control".resetAxes);
	#instReset_J3(Axis := "J3_SCARA_Arm3D", Execute := "GDB_Control".resetAxes);
	#instReset_J4(Axis := "J4_SCARA_Arm3D", Execute := "GDB_Control".resetAxes);
	#instReset_Kin(Axis := "ScaraArm3D",    Execute := "GDB_Control".resetAxes);

	"GDB_Control".axesError := #instPower_J1.Error
	                            OR #instPower_J2.Error
	                            OR #instPower_J3.Error
	                            OR #instPower_J4.Error
	                            OR #instHome_J1.Error
	                            OR #instHome_J2.Error
	                            OR #instHome_J3.Error
	                            OR #instHome_J4.Error
	                            OR #instReset_J1.Error
	                            OR #instReset_J2.Error
	                            OR #instReset_J3.Error
	                            OR #instReset_J4.Error
	                            OR #instReset_Kin.Error;

	// =====================================================================
	// REGION Home — per-axis MC_Home calls
	// HomeMode[i]=7 ("set actual position") — no physical homing motion.
	// HomePos[i] from Startup OB (all zeros for SCARA zero pose).
	// =====================================================================
	#instHome_J1(Axis     := "J1_SCARA_Arm3D",
	             Execute  := "GDB_Control".homeAxes,
	             Position := "GDB_Control".HomePos[1],
	             Mode     := "GDB_Control".HomeMode[1]);

	#instHome_J2(Axis     := "J2_SCARA_Arm3D",
	             Execute  := "GDB_Control".homeAxes,
	             Position := "GDB_Control".HomePos[2],
	             Mode     := "GDB_Control".HomeMode[2]);

	#instHome_J3(Axis     := "J3_SCARA_Arm3D",
	             Execute  := "GDB_Control".homeAxes,
	             Position := "GDB_Control".HomePos[3],
	             Mode     := "GDB_Control".HomeMode[3]);

	#instHome_J4(Axis     := "J4_SCARA_Arm3D",
	             Execute  := "GDB_Control".homeAxes,
	             Position := "GDB_Control".HomePos[4],
	             Mode     := "GDB_Control".HomeMode[4]);

	// Mirror axesHomed = AND of all 4 Done outputs
	IF #instHome_J1.Done
	   AND #instHome_J2.Done
	   AND #instHome_J3.Done
	   AND #instHome_J4.Done
	THEN
	    "GDB_Control".axesHomed := TRUE;
	END_IF;

END_FUNCTION_BLOCK
